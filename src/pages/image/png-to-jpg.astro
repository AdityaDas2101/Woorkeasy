---
/**
 * PNG to JPG Tool
 * Convert PNG images to JPG format with adjustable quality.
 * Fills transparent areas with white background.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="PNG to JPG"
  metaTitle="PNG to JPG Converter Free  - Convert Images Online | Woorkeasy"
  description="Convert PNG to JPG online free with adjustable quality. Reduce file size while maintaining clarity. Browser-based PNG to JPG converter, no upload needed."
  heading="PNG to JPG."
  category="Image Tools"
>
  <div id="png-to-jpg-app" class="flex flex-col gap-6">
    <!-- Upload Zone -->
    <div
      id="upload-zone"
      class="upload-zone flex flex-col items-center justify-center gap-3 p-12 border-2 border-dashed border-neutral-300 rounded-lg cursor-pointer hover:border-neutral-400 transition-colors"
    >
      <span class="text-4xl">-</span>
      <p class="body-md text-neutral-600 dark:text-neutral-400 text-center">
        Drop PNG files here or <span class="text-neutral-900 dark:text-neutral-100 font-medium underline">browse</span>
      </p>
      <p class="body-sm text-neutral-500">Supports multiple files  PNG only</p>
      <input id="file-input" type="file" accept=".png,image/png" multiple class="hidden" />
    </div>

    <!-- Options -->
    <div id="options-panel" class="hidden p-4 bg-neutral-50 dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700">
      <div class="flex flex-wrap items-center gap-6">
        <div class="flex items-center gap-3">
          <label for="quality-slider" class="body-sm font-medium text-neutral-700 dark:text-neutral-300">Quality:</label>
          <input id="quality-slider" type="range" min="10" max="100" value="92" class="w-32 accent-neutral-900" />
          <span id="quality-value" class="body-sm text-neutral-700 dark:text-neutral-300 font-medium w-10">92%</span>
        </div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="bg-color-toggle" class="accent-neutral-900" />
          <span class="body-sm text-neutral-700 dark:text-neutral-300">Custom background color</span>
        </label>
        <input id="bg-color-input" type="color" value="#ffffff" class="hidden w-8 h-8 rounded border border-neutral-200 cursor-pointer" />
      </div>
    </div>

    <!-- File List -->
    <div id="file-list" class="hidden flex flex-col gap-3"></div>

    <!-- Actions -->
    <div id="action-bar" class="hidden flex flex-wrap items-center gap-3">
      <button id="convert-btn" class="btn-primary">Convert All</button>
      <button id="download-all-btn" class="btn-secondary hidden">Download All</button>
      <button id="clear-btn" class="btn-secondary ml-auto">Clear</button>
    </div>

    <!-- Status -->
    <div id="status" class="hidden body-sm text-neutral-600 dark:text-neutral-400 flex items-center gap-2">
      <svg class="animate-spin h-4 w-4 text-neutral-500" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span id="status-text">Converting...</span>
    </div>

    <!-- Results -->
    <div id="results" class="hidden flex flex-col gap-4"></div>
  </div>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Use PNG to JPG Converter</h2>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Drop or browse to select your PNG file(s)</li>
        <li>Adjust quality slider and background color</li>
        <li>Click "Convert All" and download your JPG files</li>
      </ol>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Adjustable quality from 10% to 100%</li>
        <li>Custom background color for transparency fill</li>
        <li>Batch convert multiple PNG files at once</li>
        <li>Significant file size reduction compared to PNG</li>
        <li>Fully client-side processing, no upload</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use Our PNG to JPG Converter</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">PNG files are great for quality but can be too large for web use. Convert PNG to JPG to dramatically reduce file sizes while maintaining good visual quality. Our tool gives you full control over the output quality and handles transparency by letting you choose a background fill color.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is PNG to JPG conversion free?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Yes, completely free with unlimited conversions and no sign-up required.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">What happens to transparent areas?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Transparent areas are filled with your chosen background color (white by default).</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">How much smaller will the file be?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">JPG files are typically 50-80% smaller than PNG at similar quality settings.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I adjust the quality?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Yes, use the quality slider from 10% to 100% to balance size and quality.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Are my images uploaded?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">No, everything runs locally in your browser. Your files stay private.</p></div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">Related Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-4">
        <a href="/image/jpg-to-png" class="btn-secondary text-center no-underline text-sm">JPG to PNG</a>
        <a href="/image/compress" class="btn-secondary text-center no-underline text-sm">Compress Image</a>
        <a href="/image/crop" class="btn-secondary text-center no-underline text-sm">Crop Image</a>
        <a href="/image/to-webp" class="btn-secondary text-center no-underline text-sm">JPG/PNG to WebP</a>
      </div>
    </section>
  </div>
</ToolLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is PNG to JPG conversion free?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, completely free with unlimited conversions and no sign-up required." }
    },
    {
      "@type": "Question",
      "name": "What happens to transparent areas?",
      "acceptedAnswer": { "@type": "Answer", "text": "Transparent areas are filled with your chosen background color (white by default)." }
    },
    {
      "@type": "Question",
      "name": "How much smaller will the file be?",
      "acceptedAnswer": { "@type": "Answer", "text": "JPG files are typically 50-80% smaller than PNG at similar quality settings." }
    },
    {
      "@type": "Question",
      "name": "Can I adjust the quality?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, use the quality slider from 10% to 100% to balance size and quality." }
    },
    {
      "@type": "Question",
      "name": "Are my images uploaded?",
      "acceptedAnswer": { "@type": "Answer", "text": "No, everything runs locally in your browser. Your files stay private." }
    }
  ]
}
</script>

<script>
  const uploadZone = document.getElementById('upload-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const optionsPanel = document.getElementById('options-panel')!;
  const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
  const qualityValue = document.getElementById('quality-value')!;
  const bgColorToggle = document.getElementById('bg-color-toggle') as HTMLInputElement;
  const bgColorInput = document.getElementById('bg-color-input') as HTMLInputElement;
  const fileList = document.getElementById('file-list')!;
  const actionBar = document.getElementById('action-bar')!;
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement;
  const downloadAllBtn = document.getElementById('download-all-btn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('status')!;
  const statusText = document.getElementById('status-text')!;
  const results = document.getElementById('results')!;

  interface FileEntry { file: File; dataUrl?: string; converted: boolean; }
  let files: FileEntry[] = [];

  qualitySlider.addEventListener('input', () => { qualityValue.textContent = qualitySlider.value + '%'; });
  bgColorToggle.addEventListener('change', () => { bgColorInput.classList.toggle('hidden', !bgColorToggle.checked); });

  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('border-neutral-500'); });
  uploadZone.addEventListener('dragleave', () => { uploadZone.classList.remove('border-neutral-500'); });
  uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.classList.remove('border-neutral-500'); if (e.dataTransfer?.files) addFiles(e.dataTransfer.files); });
  fileInput.addEventListener('change', () => { if (fileInput.files) addFiles(fileInput.files); });

  function addFiles(fl: FileList) {
    const pngs = Array.from(fl).filter(f => f.type === 'image/png' || f.name.toLowerCase().endsWith('.png'));
    if (!pngs.length) { alert('Please select PNG files only.'); return; }
    pngs.forEach(f => files.push({ file: f, converted: false }));
    renderFileList();
    optionsPanel.classList.remove('hidden');
    actionBar.classList.remove('hidden');
    results.classList.add('hidden');
    downloadAllBtn.classList.add('hidden');
  }

  function renderFileList() {
    fileList.classList.remove('hidden');
    fileList.innerHTML = files.map((e, i) => `
      <div class="flex items-center gap-3 p-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 rounded-lg">
        <span class="text-lg">-</span>
        <div class="flex-1 min-w-0">
          <p class="body-sm font-medium text-neutral-900 dark:text-neutral-100 truncate">${e.file.name}</p>
          <p class="caption-mono text-neutral-500">${(e.file.size / 1024).toFixed(1)} KB</p>
        </div>
        <button data-remove="${i}" class="text-neutral-400 hover:text-red-500 transition-colors text-lg leading-none">&times;</button>
      </div>
    `).join('');
    fileList.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', () => {
        files.splice(parseInt((btn as HTMLElement).dataset.remove!), 1);
        if (!files.length) resetUI(); else renderFileList();
      });
    });
  }

  function resetUI() {
    files = [];
    fileList.classList.add('hidden'); fileList.innerHTML = '';
    optionsPanel.classList.add('hidden'); actionBar.classList.add('hidden');
    results.classList.add('hidden'); results.innerHTML = '';
    downloadAllBtn.classList.add('hidden'); fileInput.value = '';
  }

  clearBtn.addEventListener('click', resetUI);

  convertBtn.addEventListener('click', async () => {
    if (!files.length) return;
    const quality = parseInt(qualitySlider.value) / 100;
    const bgColor = bgColorToggle.checked ? bgColorInput.value : '#ffffff';
    statusEl.classList.remove('hidden');
    results.classList.add('hidden'); results.innerHTML = '';
    convertBtn.disabled = true;

    for (let i = 0; i < files.length; i++) {
      statusText.textContent = `Converting ${i + 1} of ${files.length}...`;
      const entry = files[i];
      try {
        entry.dataUrl = await convertPngToJpg(entry.file, quality, bgColor);
        entry.converted = true;
      } catch { entry.converted = false; }
    }

    statusEl.classList.add('hidden');
    convertBtn.disabled = false;
    showResults();
  });

  function convertPngToJpg(file: File, quality: number, bgColor: string): Promise<string> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        const ctx = canvas.getContext('2d')!;
        ctx.fillStyle = bgColor;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(img, 0, 0);
        resolve(canvas.toDataURL('image/jpeg', quality));
        URL.revokeObjectURL(img.src);
      };
      img.onerror = () => { URL.revokeObjectURL(img.src); reject(new Error('Failed')); };
      img.src = URL.createObjectURL(file);
    });
  }

  function showResults() {
    results.classList.remove('hidden');
    const converted = files.filter(f => f.converted);
    results.innerHTML = converted.map((e, i) => {
      const newName = e.file.name.replace(/\.png$/i, '.jpg');
      const origKB = (e.file.size / 1024).toFixed(1);
      const newKB = e.dataUrl ? ((e.dataUrl.length * 3 / 4) / 1024).toFixed(1) : '?';
      return `
        <div class="flex items-center gap-3 p-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 rounded-lg">
          <img src="${e.dataUrl}" alt="${newName}" class="w-12 h-12 object-cover rounded border border-neutral-200 dark:border-neutral-700" />
          <div class="flex-1 min-w-0">
            <p class="body-sm font-medium text-neutral-900 dark:text-neutral-100 truncate">${newName}</p>
            <p class="caption-mono text-neutral-500">${origKB} KB ' ~${newKB} KB</p>
          </div>
          <button data-dl="${i}" class="btn-secondary text-sm">Download</button>
        </div>`;
    }).join('');
    results.querySelectorAll('[data-dl]').forEach(btn => {
      btn.addEventListener('click', () => {
        const entry = converted[parseInt((btn as HTMLElement).dataset.dl!)];
        if (!entry.dataUrl) return;
        const a = document.createElement('a');
        a.href = entry.dataUrl;
        a.download = entry.file.name.replace(/\.png$/i, '.jpg');
        a.click();
      });
    });
    if (converted.length > 1) downloadAllBtn.classList.remove('hidden');
  }

  downloadAllBtn.addEventListener('click', () => {
    files.filter(f => f.converted).forEach((e, i) => {
      setTimeout(() => {
        if (!e.dataUrl) return;
        const a = document.createElement('a');
        a.href = e.dataUrl;
        a.download = e.file.name.replace(/\.png$/i, '.jpg');
        a.click();
      }, i * 300);
    });
  });
</script>



