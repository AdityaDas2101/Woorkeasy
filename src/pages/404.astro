---
/**
 * 404 Not Found
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found (404) | Woorkeasy"
  description="The page you are looking for does not exist. Browse our free online tools for images, PDFs, finance, and development."
>
  <section class="flex-1 flex items-center justify-center px-6 py-16 md:py-24">
    <div class="max-w-lg w-full">
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-level-4 dark:border dark:border-neutral-800 p-8 md:p-12 text-center">
        <p class="text-7xl md:text-8xl font-bold bg-gradient-to-br from-violet-500 via-purple-500 to-pink-500 bg-clip-text text-transparent select-none">
          404
        </p>
        <div class="w-16 h-16 mx-auto mt-6 bg-violet-100 dark:bg-violet-900/30 rounded-full flex items-center justify-center">
          <svg class="w-8 h-8 text-violet-600 dark:text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 12l3 3 5-5"/>
          </svg>
        </div>
        <h1 class="display-md text-neutral-900 dark:text-neutral-100 mt-4">Page Not Found</h1>
        <p class="body-md text-neutral-600 dark:text-neutral-400 mt-2">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
          <a href="/" class="btn-primary no-underline">Go Home</a>
          <a href="/#tools" class="btn-secondary no-underline">Browse Tools</a>
        </div>
      </div>
      <div class="mt-6 p-4 bg-neutral-100 dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800">
        <p class="caption-mono text-neutral-500 text-center">Popular tools you might be looking for</p>
        <div class="flex flex-wrap justify-center gap-2 mt-3">
          <a href="/image/jpg-to-png" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">JPG to PNG</a>
          <a href="/image/compress" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Compress Image</a>
          <a href="/pdf/merge-pdf" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Merge PDF</a>
          <a href="/dev/base64" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Base64</a>
          <a href="/finance/csv-to-excel" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">CSV to Excel</a>
          <a href="/image/background-remover" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Bg Remover</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
