---
/**
 * JPG to PDF Converter
 * Uses jsPDF to convert one or more images into a PDF document.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="JPG to PDF"
  metaTitle="JPG to PDF Online Free - Convert Images to PDF | Woorkeasy"
  description="Convert JPG to PDF online free. Combine multiple images into a single PDF document with page size options. No upload, instant download, 100% free."
  heading="Convert Images to PDF"
  category="PDF Tools"
>
  <div id="jpg-pdf-app">
    <!-- Upload Zone -->
    <div id="upload-zone" class="upload-zone p-12 text-center cursor-pointer">
      <div class="flex flex-col items-center gap-4">
        <svg class="w-12 h-12 text-neutral-500" viewBox="0 0 48 48" fill="none">
          <path d="M24 32V16m0 0l-6 6m6-6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="8" y="8" width="32" height="32" rx="4" stroke="currentColor" stroke-width="2"/>
        </svg>
        <p class="body-md text-neutral-600">Drag & drop images here, or <span class="text-blue-600 font-medium">browse</span></p>
        <p class="body-sm text-neutral-500">Supports JPG, PNG, WebP " each image = one PDF page</p>
      </div>
      <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp" multiple class="hidden" />
    </div>

    <!-- Controls -->
    <div id="controls" class="hidden mt-6">
      <div class="flex flex-col sm:flex-row gap-6">
        <div class="flex-1">
          <label class="body-sm text-neutral-600 font-medium block mb-2">Page Size</label>
          <select id="page-size" class="w-full px-3 py-2 border border-neutral-200 rounded-md body-sm bg-white">
            <option value="a4">A4</option>
            <option value="letter">Letter</option>
            <option value="fit">Fit to Image</option>
          </select>
        </div>
        <div class="flex-1">
          <label class="body-sm text-neutral-600 font-medium block mb-2">Orientation</label>
          <select id="orientation" class="w-full px-3 py-2 border border-neutral-200 rounded-md body-sm bg-white">
            <option value="portrait">Portrait</option>
            <option value="landscape">Landscape</option>
          </select>
        </div>
      </div>

      <!-- File list preview -->
      <div id="file-list" class="mt-4 flex flex-col gap-2">
        <p class="body-sm text-neutral-500 mb-1">Drag items or use arrows to reorder:</p>
      </div>

      <button id="convert-btn" class="btn-primary mt-6">
        Create PDF
      </button>
    </div>

    <!-- Loading -->
    <div id="loading" class="hidden mt-6 text-center">
      <div class="inline-flex items-center gap-3">
        <svg class="animate-spin w-5 h-5 text-[var(--color-primary)]" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-25"/>
          <path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <span class="body-sm text-neutral-600">Creating PDF...</span>
      </div>
    </div>

    <!-- Result -->
    <div id="result" class="hidden mt-8">
      <h2 class="display-sm text-neutral-900 mb-4">PDF Ready</h2>
      <div class="flex items-center justify-between p-4 bg-neutral-50 rounded-lg">
        <div>
          <p id="result-name" class="body-sm text-neutral-900 font-medium"></p>
          <p id="result-info" class="caption-mono text-neutral-500"></p>
        </div>
        <a id="download-btn" class="btn-primary text-sm no-underline" style="padding: 6px 16px;" download="images.pdf">Download PDF</a>
      </div>
    </div>
  </div>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Use JPG to PDF Converter</h2>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Upload your images " Drag & drop JPG, PNG, or WebP images or click to browse.</li>
        <li>Reorder pages " Drag items or use the arrow buttons to arrange them in your desired order.</li>
        <li>Customize settings " Choose page size (A4, Letter, or Fit to Image) and orientation.</li>
        <li>Convert and download " Click "Create PDF" and download your combined PDF instantly.</li>
      </ol>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Multiple image formats " Supports JPG, PNG, and WebP images.</li>
        <li>Drag-and-drop reordering " Arrange pages in any order before conversion.</li>
        <li>Customizable page size " A4, Letter, or auto-fit to image dimensions.</li>
        <li>Portrait or landscape orientation " Flexible layout for any document type.</li>
        <li>100% browser-based " No files uploaded to servers, complete privacy.</li>
        <li>Unlimited conversions " No sign-up, no watermarks, no page limits.</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use Our JPG to PDF Converter</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Our free JPG to PDF online converter lets you combine multiple images into a single PDF document in seconds. Whether digitizing paperwork, creating portfolios, or compiling photo albums, this tool handles all popular image formats. Everything runs in your browser " no uploads, no privacy risks, no file size limits.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is this JPG to PDF converter really free?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, completely free with no hidden charges, watermarks, or page limits.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">What image formats are supported?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">JPG, PNG, and WebP images are all supported. Each image becomes one page in the PDF.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I combine multiple images into one PDF?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, upload multiple images and each becomes a separate page in your combined PDF document.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I reorder images before converting?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, drag and drop images or use the arrow buttons to rearrange them in any order you like.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Are my images uploaded to a server?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">No, all processing happens in your browser locally " your files never leave your device.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">What page sizes are available?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Choose from A4, Letter, or Fit to Image which automatically matches image dimensions.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is there a limit on the number of images?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">No, you can combine as many images as you like with no restrictions.</p>
        </div>
      </div>
    </section>

    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">Related Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-4">
        <a href="/pdf/merge-pdf" class="btn-secondary text-center no-underline text-sm">Merge PDF</a>
        <a href="/pdf/split-pdf" class="btn-secondary text-center no-underline text-sm">Split PDF</a>
        <a href="/pdf/pdf-to-image" class="btn-secondary text-center no-underline text-sm">PDF to Image</a>
        <a href="/pdf/rotate-pdf" class="btn-secondary text-center no-underline text-sm">Rotate PDF</a>
      </div>
    </section>
  </div>
</ToolLayout>

