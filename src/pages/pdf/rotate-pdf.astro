---
/**
 * Rotate PDF Tool
 * Rotate PDF pages by 90, 180, or 270.
 * Uses pdf-lib for PDF manipulation.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="Rotate PDF"
  metaTitle="Rotate PDF Online Free  - Rotate PDF Pages | Woorkeasy"
  description="Rotate PDF pages online free. Permanently rotate pages 90, 180, or 270. No upload, instant processing, secure browser-based PDF rotator tool."
  heading="Rotate PDF."
  category="PDF Tools"
>
  <div id="rotate-pdf-app" class="flex flex-col gap-6">
    <!-- Upload Zone -->
    <div
      id="upload-zone"
      class="upload-zone flex flex-col items-center justify-center gap-3 p-12 border-2 border-dashed border-neutral-300 rounded-lg cursor-pointer hover:border-neutral-400 transition-colors"
    >
      <span class="text-4xl">"</span>
      <p class="body-md text-neutral-600 dark:text-neutral-400 text-center">
        Drop a PDF file here or <span class="text-neutral-900 dark:text-neutral-100 font-medium underline">browse</span>
      </p>
      <p class="body-sm text-neutral-500">Single PDF file</p>
      <input id="file-input" type="file" accept=".pdf,application/pdf" class="hidden" />
    </div>

    <!-- File Info -->
    <div id="file-info" class="hidden p-4 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 rounded-lg">
      <div class="flex items-center gap-3">
        <span class="text-lg">"</span>
        <div class="flex-1 min-w-0">
          <p id="file-name" class="body-sm font-medium text-neutral-900 dark:text-neutral-100 truncate"></p>
          <p id="file-pages" class="caption-mono text-neutral-500"></p>
        </div>
        <button id="clear-btn" class="text-neutral-400 hover:text-red-500 transition-colors text-lg leading-none">&times;</button>
      </div>
    </div>

    <!-- Options -->
    <div id="options-panel" class="hidden p-4 bg-neutral-50 dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700">
      <div class="flex flex-col gap-4">
        <!-- Rotation Angle -->
        <div class="flex flex-wrap items-center gap-4">
          <span class="body-sm font-medium text-neutral-700 dark:text-neutral-300">Rotate:</span>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="angle" value="90" checked class="accent-neutral-900" />
            <span class="body-sm text-neutral-700 dark:text-neutral-300">90 clockwise</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="angle" value="180" class="accent-neutral-900" />
            <span class="body-sm text-neutral-700 dark:text-neutral-300">180</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="angle" value="270" class="accent-neutral-900" />
            <span class="body-sm text-neutral-700 dark:text-neutral-300">90 counter-clockwise</span>
          </label>
        </div>

        <!-- Page Selection -->
        <div class="flex flex-wrap items-center gap-4">
          <span class="body-sm font-medium text-neutral-700 dark:text-neutral-300">Apply to:</span>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="scope" value="all" checked class="accent-neutral-900" />
            <span class="body-sm text-neutral-700 dark:text-neutral-300">All pages</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="scope" value="custom" class="accent-neutral-900" />
            <span class="body-sm text-neutral-700 dark:text-neutral-300">Specific pages</span>
          </label>
        </div>
        <div id="page-input-group" class="hidden">
          <input
            id="page-input"
            type="text"
            placeholder="e.g., 1, 3, 5-8"
            class="w-full px-4 py-2 border border-neutral-200 dark:border-neutral-700 rounded-lg body-sm bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:border-neutral-900 dark:focus:border-neutral-400"
          />
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div id="action-bar" class="hidden flex flex-wrap items-center gap-3">
      <button id="rotate-btn" class="btn-primary">Rotate & Download</button>
    </div>

    <!-- Status -->
    <div id="status" class="hidden body-sm text-neutral-600 dark:text-neutral-400 flex items-center gap-2">
      <svg class="animate-spin h-4 w-4 text-neutral-500" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span id="status-text">Rotating pages...</span>
    </div>

    <!-- Result -->
    <div id="result" class="hidden p-4 bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-800 rounded-lg">
      <div class="flex items-center gap-3">
        <span class="text-lg"></span>
        <p class="body-sm text-neutral-900 dark:text-neutral-100 flex-1">PDF rotated successfully!</p>
        <button id="download-btn" class="btn-primary text-sm">Download</button>
      </div>
    </div>
  </div>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Use Rotate PDF Tool</h2>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Upload your PDF " Drag & drop a PDF file or click to browse.</li>
        <li>Choose rotation " Select 90 clockwise, 180, or 90 counter-clockwise.</li>
        <li>Apply and download " Rotate all pages or specific ones, then download your rotated PDF.</li>
      </ol>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Three rotation angles " Rotate 90 clockwise, 180 upside down, or 90 counter-clockwise.</li>
        <li>Selective page rotation " Apply rotation to all pages or enter specific page numbers.</li>
        <li>Permanent changes " Rotation is saved directly into the PDF file.</li>
        <li>Instant processing " Fast page rotation with immediate download.</li>
        <li>100% secure " All processing happens in your browser, files never leave your device.</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use Our PDF Rotator</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Our free rotate PDF online tool lets you permanently rotate PDF pages by 90, 180, or 270. Perfect for fixing scanned documents with wrong orientation, adjusting landscape pages, or correcting upside-down content. Apply changes to all pages or specific ones with instant download. No uploads, no registration, completely free.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is rotation permanent in the PDF?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, rotation is permanently saved into the PDF file with no way to undo after download.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I rotate specific pages only?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, choose "Specific pages" and enter page numbers like 1, 3, 5-8 to rotate only those pages.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">What rotation angles are available?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">90 clockwise, 180 (upside down), and 90 counter-clockwise (270).</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Are my files uploaded to a server?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">No, all processing is done locally in your browser for complete privacy.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Will the PDF quality be affected by rotation?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">No, rotating PDF pages does not reduce image or text quality in any way.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I process multiple PDFs?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">You can process one PDF at a time with unlimited re-uploads for different files.</p>
        </div>
      </div>
    </section>

    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">Related Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-4">
        <a href="/pdf/merge-pdf" class="btn-secondary text-center no-underline text-sm">Merge PDF</a>
        <a href="/pdf/split-pdf" class="btn-secondary text-center no-underline text-sm">Split PDF</a>
        <a href="/pdf/pdf-to-image" class="btn-secondary text-center no-underline text-sm">PDF to Image</a>
        <a href="/pdf/jpg-to-pdf" class="btn-secondary text-center no-underline text-sm">JPG to PDF</a>
      </div>
    </section>
  </div>
</ToolLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is rotation permanent in the PDF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, rotation is permanently saved into the PDF file with no way to undo after download."
      }
    },
    {
      "@type": "Question",
      "name": "Can I rotate specific pages only?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, choose Specific pages and enter page numbers like 1, 3, 5-8 to rotate only those pages."
      }
    },
    {
      "@type": "Question",
      "name": "What rotation angles are available?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "90 clockwise, 180 (upside down), and 90 counter-clockwise (270)."
      }
    },
    {
      "@type": "Question",
      "name": "Are my files uploaded to a server?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, all processing is done locally in your browser for complete privacy."
      }
    },
    {
      "@type": "Question",
      "name": "Will the PDF quality be affected by rotation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, rotating PDF pages does not reduce image or text quality in any way."
      }
    },
    {
      "@type": "Question",
      "name": "Can I process multiple PDFs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can process one PDF at a time with unlimited re-uploads for different files."
      }
    }
  ]
}
</script>

<script>
  import { PDFDocument, degrees } from 'pdf-lib';

  const uploadZone = document.getElementById('upload-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileInfo = document.getElementById('file-info')!;
  const fileName = document.getElementById('file-name')!;
  const filePages = document.getElementById('file-pages')!;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const optionsPanel = document.getElementById('options-panel')!;
  const pageInputGroup = document.getElementById('page-input-group')!;
  const pageInput = document.getElementById('page-input') as HTMLInputElement;
  const actionBar = document.getElementById('action-bar')!;
  const rotateBtn = document.getElementById('rotate-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('status')!;
  const statusText = document.getElementById('status-text')!;
  const resultEl = document.getElementById('result')!;
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;

  let pdfBytes: ArrayBuffer | null = null;
  let totalPages = 0;
  let resultBlob: Blob | null = null;
  let originalName = '';

  // Scope toggle
  document.querySelectorAll('input[name="scope"]').forEach(r => {
    r.addEventListener('change', () => {
      const scope = (document.querySelector('input[name="scope"]:checked') as HTMLInputElement)?.value;
      pageInputGroup.classList.toggle('hidden', scope !== 'custom');
    });
  });

  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('border-neutral-500'); });
  uploadZone.addEventListener('dragleave', () => { uploadZone.classList.remove('border-neutral-500'); });
  uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.classList.remove('border-neutral-500'); if (e.dataTransfer?.files[0]) loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });

  async function loadFile(file: File) {
    pdfBytes = await file.arrayBuffer();
    originalName = file.name;
    const pdf = await PDFDocument.load(pdfBytes);
    totalPages = pdf.getPageCount();
    fileName.textContent = file.name;
    filePages.textContent = `${totalPages} page${totalPages > 1 ? 's' : ''}`;
    fileInfo.classList.remove('hidden');
    optionsPanel.classList.remove('hidden');
    actionBar.classList.remove('hidden');
    uploadZone.classList.add('hidden');
    resultEl.classList.add('hidden');
  }

  clearBtn.addEventListener('click', () => {
    pdfBytes = null; totalPages = 0; resultBlob = null;
    fileInfo.classList.add('hidden');
    optionsPanel.classList.add('hidden');
    actionBar.classList.add('hidden');
    resultEl.classList.add('hidden');
    uploadZone.classList.remove('hidden');
    fileInput.value = '';
  });

  function parsePages(input: string, max: number): number[] {
    const pages: Set<number> = new Set();
    const parts = input.split(',').map(s => s.trim()).filter(Boolean);
    for (const part of parts) {
      if (part.includes('-')) {
        const [start, end] = part.split('-').map(n => parseInt(n.trim()));
        if (!isNaN(start) && !isNaN(end)) {
          for (let i = Math.max(1, start); i <= Math.min(max, end); i++) pages.add(i);
        }
      } else {
        const n = parseInt(part);
        if (!isNaN(n) && n >= 1 && n <= max) pages.add(n);
      }
    }
    return Array.from(pages).sort((a, b) => a - b);
  }

  rotateBtn.addEventListener('click', async () => {
    if (!pdfBytes) return;

    const angle = parseInt((document.querySelector('input[name="angle"]:checked') as HTMLInputElement)?.value || '90');
    const scope = (document.querySelector('input[name="scope"]:checked') as HTMLInputElement)?.value || 'all';

    statusEl.classList.remove('hidden');
    resultEl.classList.add('hidden');
    rotateBtn.disabled = true;
    statusText.textContent = 'Rotating pages...';

    try {
      const pdf = await PDFDocument.load(pdfBytes);
      let pageIndices: number[];

      if (scope === 'all') {
        pageIndices = Array.from({ length: totalPages }, (_, i) => i);
      } else {
        const parsed = parsePages(pageInput.value, totalPages);
        if (parsed.length === 0) { alert('No valid pages specified.'); statusEl.classList.add('hidden'); rotateBtn.disabled = false; return; }
        pageIndices = parsed.map(p => p - 1);
      }

      for (const idx of pageIndices) {
        const page = pdf.getPage(idx);
        const currentRotation = page.getRotation().angle;
        page.setRotation(degrees(currentRotation + angle));
      }

      const savedBytes = await pdf.save();
      resultBlob = new Blob([savedBytes], { type: 'application/pdf' });
      resultEl.classList.remove('hidden');
    } catch (err: any) {
      alert('Error: ' + (err.message || 'Failed to rotate PDF'));
    }

    statusEl.classList.add('hidden');
    rotateBtn.disabled = false;
  });

  downloadBtn.addEventListener('click', () => {
    if (!resultBlob) return;
    const url = URL.createObjectURL(resultBlob);
    const a = document.createElement('a');
    a.href = url;
    a.download = originalName.replace(/\.pdf$/i, '-rotated.pdf');
    a.click();
    URL.revokeObjectURL(url);
  });
</script>



