---
/**
 * Merge PDF Tool
 * Uses pdf-lib to combine multiple PDF files into one.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="Merge PDF"
  metaTitle="Merge PDF Online Free - Combine PDF Files | Woorkeasy"
  description="Merge PDF files online free. Combine multiple PDFs into one document instantly. No upload, no sign-up, unlimited pages. Fast PDF merger tool."
  heading="Merge PDF Files"
  category="PDF Tools"
  tryNextTools={[
    { name: 'Split PDF', href: '/pdf/split-pdf/' },
    { name: 'PDF to Image', href: '/pdf/pdf-to-image/' },
    { name: 'JPG to PDF', href: '/pdf/jpg-to-pdf/' },
    { name: 'OFX to Excel', href: '/finance/ofx-to-excel/' },
  ]}
>
  <div id="merge-app">
    <!-- Upload Zone -->
    <div id="upload-zone" class="upload-zone p-12 text-center cursor-pointer">
      <div class="flex flex-col items-center gap-4">
        <svg class="w-12 h-12 text-neutral-500" viewBox="0 0 48 48" fill="none">
          <path d="M24 32V16m0 0l-6 6m6-6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="8" y="8" width="32" height="32" rx="4" stroke="currentColor" stroke-width="2"/>
        </svg>
        <p class="body-md text-neutral-600">Drag & drop PDF files here, or <span class="text-blue-600 font-medium">browse</span></p>
        <p class="body-sm text-neutral-500">Select 2 or more PDF files to merge</p>
      </div>
      <input type="file" id="file-input" accept="application/pdf" multiple class="hidden" />
    </div>

    <!-- File List / Reorder -->
    <div id="file-list-section" class="hidden mt-6">
      <p class="body-sm text-neutral-600 font-medium mb-2">Files to merge (drag to reorder):</p>
      <div id="file-list" class="flex flex-col gap-2"></div>
      <button id="merge-btn" class="btn-primary mt-6">
        Merge PDFs
      </button>
    </div>

    <!-- Loading -->
    <div id="loading" class="hidden mt-6 text-center">
      <div class="inline-flex items-center gap-3">
        <svg class="animate-spin w-5 h-5 text-[var(--color-primary)]" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-25"/>
          <path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <span class="body-sm text-neutral-600">Merging PDFs...</span>
      </div>
    </div>

    <!-- Result -->
    <div id="result" class="hidden mt-8">
      <h2 class="display-sm text-neutral-900 mb-4">Merged PDF Ready</h2>
      <div class="flex items-center justify-between p-4 bg-neutral-50 rounded-lg">
        <div>
          <p class="body-sm text-neutral-900 font-medium">merged.pdf</p>
          <p id="result-info" class="caption-mono text-neutral-500"></p>
        </div>
        <a id="download-btn" class="btn-primary text-sm no-underline" style="padding: 6px 16px;" download="merged.pdf">Download PDF</a>
      </div>
    </div>
  </div>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Merge PDF Files Online</h2>
      <p class="body-md text-neutral-600 dark:text-neutral-400 mt-2">Combining multiple PDF documents into one file is straightforward with our browser-based merger:</p>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Upload PDF files &mdash; Drag & drop two or more PDF files or click to browse from your device.</li>
        <li>Review the order &mdash; Files are listed in the sequence they will be merged. Upload in your preferred order.</li>
        <li>Merge and download &mdash; Click "Merge PDFs" and download your combined document instantly.</li>
      </ol>
      <p class="body-md text-neutral-600 dark:text-neutral-400 mt-4">All processing happens locally using your browser &mdash; no files are ever uploaded to any server, keeping your documents private and secure.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li><strong>Unlimited File Merging</strong> &mdash; Combine as many PDF files as you need in a single session with no restrictions on page count or document size.</li>
        <li><strong>Preserves Original Quality</strong> &mdash; All pages retain their original formatting, embedded fonts, vector graphics, and image quality with zero compression loss.</li>
        <li><strong>No File Size Limits</strong> &mdash; Merge large PDF documents without worrying about upload caps or processing limits since everything runs locally.</li>
        <li><strong>Browser-Based Privacy</strong> &mdash; Your documents are processed entirely in your browser using pdf-lib. Nothing is uploaded, stored, or shared with any third party.</li>
        <li><strong>Zero Sign-Up Required</strong> &mdash; No account creation, no email verification, no subscription. Just upload, merge, and download.</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use a Free Online PDF Merger</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Merging PDF files is one of the most common document management tasks for professionals, students, and businesses alike. Whether you need to combine multiple invoice PDFs into a single file for accounting, merge scanned contract pages into one complete agreement, or assemble separate report chapters into a unified document, a reliable PDF merger saves hours of manual work.</p>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Traditional PDF editing software like Adobe Acrobat requires expensive subscriptions and heavy installations. Desktop applications may not be available when you are working from a different computer or device. Our free online PDF merger solves this problem by working entirely within your web browser &mdash; no software to download, no plugins to install, and no accounts to create. It works on any device with a modern browser, including Windows, Mac, Linux, Chromebooks, tablets, and smartphones.</p>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Security is a critical concern when handling documents online. Unlike cloud-based PDF tools that require uploading your files to remote servers, our merger uses client-side JavaScript to process your PDFs locally. Your documents are read directly from your device, merged in your browser's memory, and the resulting file is downloaded back to your computer. Your confidential information &mdash; whether it is a business contract, financial report, or legal document &mdash; never leaves your device.</p>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">The merger handles PDFs of any size and complexity. It preserves all page elements including text layers, embedded fonts, vector images, annotations, and form fields. Whether you are merging two small documents or combining dozens of large files, the process is fast, reliable, and produces a perfectly assembled PDF ready for sharing or printing.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is this PDF merger really free?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, completely free with no limits on the number of files or pages. No subscription, no hidden fees, no account required. Use it as many times as you need.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">How many PDFs can I merge at once?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">There is no limit. Merge as many PDF files as you need in a single session. The only practical constraint is your device memory when processing very large files.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Are my PDF files uploaded to a server?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">No, all processing happens locally in your browser using client-side JavaScript. Your files never leave your device and are not stored on any server. Complete privacy guaranteed.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Will the merged PDF retain original quality?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, all pages keep their original formatting, fonts, vector graphics, and image quality. The merger does not compress or degrade any page content during the merge process.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I reorder pages before merging?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, upload your PDF files in the desired order. The merge sequence follows the file upload order, so arrange your files before clicking the merge button.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is there a file size limit?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">No artificial limits exist. You can merge PDFs of any size. Since processing happens locally, the practical limit depends on your device's available memory.</p>
        </div>
        <div>
          <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Does this work on mobile phones?</h3>
          <p class="body-md text-neutral-700 dark:text-neutral-300">Yes, the merger works on any device with a modern browser including smartphones and tablets. The interface is fully responsive and adapts to your screen size.</p>
        </div>
      </div>
    </section>
  </div>
</ToolLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is this PDF merger really free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, completely free with no limits on the number of files or pages. No subscription, no account required."
      }
    },
    {
      "@type": "Question",
      "name": "How many PDFs can I merge at once?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no limit. Merge as many PDF files as you need in a single session."
      }
    },
    {
      "@type": "Question",
      "name": "Are my PDF files uploaded to a server?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, all processing happens locally in your browser using client-side JavaScript. Your files never leave your device."
      }
    },
    {
      "@type": "Question",
      "name": "Will the merged PDF retain original quality?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, all pages keep their original formatting, fonts, vector graphics, and image quality."
      }
    },
    {
      "@type": "Question",
      "name": "Can I reorder pages before merging?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, upload your PDF files in the desired order before clicking the merge button."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a file size limit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No artificial limits exist. Since processing happens locally, the practical limit depends on your device's available memory."
      }
    },
    {
      "@type": "Question",
      "name": "Does this work on mobile phones?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, the merger works on any device with a modern browser including smartphones and tablets."
      }
    }
  ]
}
</script>

<script>
  import { PDFDocument } from 'pdf-lib';

  const uploadZone = document.getElementById('upload-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileListSection = document.getElementById('file-list-section')!;
  const fileList = document.getElementById('file-list')!;
  const mergeBtn = document.getElementById('merge-btn')!;
  const loading = document.getElementById('loading')!;
  const result = document.getElementById('result')!;
  const resultInfo = document.getElementById('result-info')!;
  const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;

  let files: File[] = [];

  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('dragover'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    if (e.dataTransfer?.files) handleFiles(Array.from(e.dataTransfer.files));
  });
  fileInput.addEventListener('change', () => { if (fileInput.files) handleFiles(Array.from(fileInput.files)); });

  function handleFiles(newFiles: File[]) {
    files = newFiles.filter(f => f.type === 'application/pdf');
    if (files.length >= 2) {
      fileListSection.classList.remove('hidden');
      renderFileList();
    }
  }

  function renderFileList() {
    fileList.innerHTML = files.map((f, i) => `
      <div class="flex items-center gap-3 p-[var(--spacing-sm)] bg-neutral-50 rounded-md">
        <span class="caption-mono text-neutral-500 w-6">${i + 1}.</span>
        <span class="body-sm text-neutral-900 flex-1">${f.name}</span>
        <span class="caption-mono text-neutral-500">${formatBytes(f.size)}</span>
      </div>
    `).join('');
  }

  mergeBtn.addEventListener('click', async () => {
    if (files.length < 2) return;
    loading.classList.remove('hidden');
    result.classList.add('hidden');

    try {
      const mergedPdf = await PDFDocument.create();

      for (const file of files) {
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await PDFDocument.load(arrayBuffer);
        const pages = await mergedPdf.copyPages(pdf, pdf.getPageIndices());
        pages.forEach(page => mergedPdf.addPage(page));
      }

      const mergedBytes = await mergedPdf.save();
      const blob = new Blob([mergedBytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);

      resultInfo.textContent = `${mergedPdf.getPageCount()} pages  ${formatBytes(blob.size)}`;
      downloadBtn.href = url;

      loading.classList.add('hidden');
      result.classList.remove('hidden');
    } catch (err) {
      loading.classList.add('hidden');
      alert(`Error: ${(err as Error).message}`);
    }
  });

  function formatBytes(bytes: number): string {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
  }
</script>



