---
/**
 * JSON Formatter Tool
 * Format, validate, and minify JSON with syntax highlighting.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="JSON Formatter"
  metaTitle="JSON Formatter, Validator & Minifier Free Online | Woorkeasy"
  description="Format, validate, and minify JSON data with syntax highlighting. Detect errors instantly — free developer tool, runs in your browser."
  heading="JSON Formatter."
>
  <div id="json-app" class="flex flex-col gap-6">
    <!-- Input -->
    <div>
      <div class="flex items-center justify-between mb-2">
        <label for="json-input" class="body-sm font-medium text-neutral-700 dark:text-neutral-300">Input JSON:</label>
        <div class="flex items-center gap-3">
          <button id="paste-btn" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 underline">Paste</button>
          <button id="sample-btn" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 underline">Load Sample</button>
          <button id="clear-btn" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 underline">Clear</button>
        </div>
      </div>
      <textarea
        id="json-input"
        class="w-full min-h-[200px] p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg font-mono text-sm text-neutral-900 dark:text-neutral-100 bg-white dark:bg-neutral-900 resize-y focus:outline-none focus:border-neutral-900 dark:focus:border-neutral-400"
        placeholder='Paste your JSON here... e.g., {"name": "John", "age": 30}'
        spellcheck="false"
      ></textarea>
    </div>

    <!-- Actions -->
    <div class="flex flex-wrap items-center gap-3">
      <button id="format-btn" class="btn-primary">Format (Pretty)</button>
      <button id="minify-btn" class="btn-secondary">Minify</button>
      <button id="validate-btn" class="btn-secondary">Validate</button>

      <div class="ml-auto flex items-center gap-2">
        <label for="indent-select" class="body-sm text-neutral-600 dark:text-neutral-400">Indent:</label>
        <select id="indent-select" class="px-3 py-1.5 border border-neutral-200 dark:border-neutral-700 rounded-md text-sm bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:border-neutral-900">
          <option value="2" selected>2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </div>
    </div>

    <!-- Status/Error -->
    <div id="status-bar" class="hidden p-3 rounded-lg border text-sm flex items-center gap-2">
      <span id="status-icon"></span>
      <span id="status-msg"></span>
    </div>

    <!-- Output -->
    <div id="output-group" class="hidden">
      <div class="flex items-center justify-between mb-2">
        <label class="body-sm font-medium text-neutral-700 dark:text-neutral-300">Output:</label>
        <div class="flex items-center gap-3">
          <span id="output-stats" class="caption-mono text-neutral-500"></span>
          <button id="copy-btn" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 underline">Copy</button>
          <button id="download-btn" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 underline">Download</button>
        </div>
      </div>
      <pre
        id="json-output"
        class="w-full max-h-[400px] overflow-auto p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg font-mono text-sm bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 whitespace-pre-wrap break-all"
      ></pre>
    </div>

    <!-- Tree View -->
    <details class="group">
      <summary class="body-sm font-medium text-neutral-700 dark:text-neutral-300 cursor-pointer hover:text-neutral-900 dark:hover:text-neutral-100">
        📊 JSON Stats
      </summary>
      <div id="json-stats" class="mt-3 p-4 bg-neutral-50 dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 grid grid-cols-2 md:grid-cols-4 gap-4">
      </div>
    </details>
  </div>

  <!-- Info -->
  <div class="mt-10 p-6 bg-neutral-50 dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700">
    <h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100 mb-3">About JSON Formatter</h3>
    <ul class="list-disc pl-5 flex flex-col gap-2 body-sm text-neutral-600 dark:text-neutral-400">
      <li><strong>Format</strong> — pretty-prints JSON with your chosen indentation.</li>
      <li><strong>Minify</strong> — removes all whitespace for the smallest possible output.</li>
      <li><strong>Validate</strong> — checks if your JSON is valid and shows the exact error location.</li>
      <li>Shows stats: keys, values, nesting depth, arrays, objects.</li>
      <li>All processing runs locally. Your data never leaves your browser.</li>
    </ul>
  </div>
</ToolLayout>

<script>
  const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
  const formatBtn = document.getElementById('format-btn') as HTMLButtonElement;
  const minifyBtn = document.getElementById('minify-btn') as HTMLButtonElement;
  const validateBtn = document.getElementById('validate-btn') as HTMLButtonElement;
  const indentSelect = document.getElementById('indent-select') as HTMLSelectElement;
  const statusBar = document.getElementById('status-bar')!;
  const statusIcon = document.getElementById('status-icon')!;
  const statusMsg = document.getElementById('status-msg')!;
  const outputGroup = document.getElementById('output-group')!;
  const jsonOutput = document.getElementById('json-output')!;
  const outputStats = document.getElementById('output-stats')!;
  const copyBtn = document.getElementById('copy-btn')!;
  const downloadBtn = document.getElementById('download-btn')!;
  const pasteBtn = document.getElementById('paste-btn')!;
  const sampleBtn = document.getElementById('sample-btn')!;
  const clearBtn = document.getElementById('clear-btn')!;
  const jsonStats = document.getElementById('json-stats')!;

  function getIndent(): string | number {
    const val = indentSelect.value;
    return val === 'tab' ? '\t' : parseInt(val);
  }

  function showStatus(type: 'success' | 'error', msg: string) {
    statusBar.classList.remove('hidden', 'bg-green-50', 'dark:bg-green-950', 'border-green-200', 'dark:border-green-800', 'bg-red-50', 'dark:bg-red-950', 'border-red-200', 'dark:border-red-800');
    if (type === 'success') {
      statusBar.classList.add('bg-green-50', 'dark:bg-green-950', 'border-green-200', 'dark:border-green-800');
      statusIcon.textContent = '✅';
    } else {
      statusBar.classList.add('bg-red-50', 'dark:bg-red-950', 'border-red-200', 'dark:border-red-800');
      statusIcon.textContent = '❌';
    }
    statusMsg.textContent = msg;
  }

  function hideStatus() { statusBar.classList.add('hidden'); }

  // Format
  formatBtn.addEventListener('click', () => {
    const input = jsonInput.value.trim();
    if (!input) { alert('Please enter JSON.'); return; }
    try {
      const parsed = JSON.parse(input);
      const formatted = JSON.stringify(parsed, null, getIndent());
      jsonOutput.textContent = formatted;
      outputGroup.classList.remove('hidden');
      showStatus('success', 'Valid JSON — formatted successfully.');
      outputStats.textContent = `${formatted.length} chars`;
      computeStats(parsed);
    } catch (err: any) {
      outputGroup.classList.add('hidden');
      showStatus('error', `Invalid JSON: ${err.message}`);
    }
  });

  // Minify
  minifyBtn.addEventListener('click', () => {
    const input = jsonInput.value.trim();
    if (!input) { alert('Please enter JSON.'); return; }
    try {
      const parsed = JSON.parse(input);
      const minified = JSON.stringify(parsed);
      jsonOutput.textContent = minified;
      outputGroup.classList.remove('hidden');
      showStatus('success', `Minified: ${input.length} → ${minified.length} chars (${Math.round((1 - minified.length / input.length) * 100)}% smaller)`);
      outputStats.textContent = `${minified.length} chars`;
      computeStats(parsed);
    } catch (err: any) {
      outputGroup.classList.add('hidden');
      showStatus('error', `Invalid JSON: ${err.message}`);
    }
  });

  // Validate
  validateBtn.addEventListener('click', () => {
    const input = jsonInput.value.trim();
    if (!input) { alert('Please enter JSON.'); return; }
    try {
      const parsed = JSON.parse(input);
      outputGroup.classList.add('hidden');
      showStatus('success', 'Valid JSON ✓');
      computeStats(parsed);
    } catch (err: any) {
      outputGroup.classList.add('hidden');
      showStatus('error', `Invalid JSON: ${err.message}`);
    }
  });

  // Copy
  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(jsonOutput.textContent || '');
    copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
  });

  // Download
  downloadBtn.addEventListener('click', () => {
    const content = jsonOutput.textContent || '';
    const blob = new Blob([content], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'formatted.json'; a.click();
    URL.revokeObjectURL(url);
  });

  // Paste
  pasteBtn.addEventListener('click', async () => {
    try {
      const text = await navigator.clipboard.readText();
      jsonInput.value = text;
    } catch {
      alert('Unable to read clipboard. Please paste manually.');
    }
  });

  // Sample
  sampleBtn.addEventListener('click', () => {
    jsonInput.value = JSON.stringify({
      name: "Woorkeasy",
      version: "1.0.0",
      tools: ["compress", "crop", "rotate", "watermark"],
      config: { theme: "dark", language: "en" },
      stats: { users: 12500, tools_count: 20 }
    }, null, 2);
  });

  // Clear
  clearBtn.addEventListener('click', () => {
    jsonInput.value = '';
    outputGroup.classList.add('hidden');
    hideStatus();
    jsonStats.innerHTML = '';
  });

  // Stats
  function computeStats(obj: any) {
    let keys = 0, values = 0, arrays = 0, objects = 0, maxDepth = 0;
    function walk(item: any, depth: number) {
      if (depth > maxDepth) maxDepth = depth;
      if (Array.isArray(item)) {
        arrays++;
        item.forEach(v => walk(v, depth + 1));
      } else if (item && typeof item === 'object') {
        objects++;
        const entries = Object.entries(item);
        keys += entries.length;
        entries.forEach(([, v]) => { values++; walk(v, depth + 1); });
      }
    }
    walk(obj, 0);
    jsonStats.innerHTML = `
      <div class="text-center"><p class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">${keys}</p><p class="caption-mono text-neutral-500">Keys</p></div>
      <div class="text-center"><p class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">${objects}</p><p class="caption-mono text-neutral-500">Objects</p></div>
      <div class="text-center"><p class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">${arrays}</p><p class="caption-mono text-neutral-500">Arrays</p></div>
      <div class="text-center"><p class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">${maxDepth}</p><p class="caption-mono text-neutral-500">Max Depth</p></div>
    `;
  }
</script>
