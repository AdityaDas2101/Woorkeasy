---
/**
 * Bank Statement Parser
 * Auto-detects QFX, OFX, CSV, and PDF bank statement files.
 * Parses each format into a standardized transaction list.
 * 100% client-side, no upload required.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="Bank Statement Parser"
  metaTitle="Bank Statement Parser Free - Auto-Detect QFX, OFX, CSV, PDF | Woorkeasy"
  description="Parse any bank statement format online free. Auto-detect QFX, OFX, CSV, and PDF files. Extract transactions into standardized CSV. No upload, secure."
  heading="Bank Statement Parser"
  category="Finance"
>
  <div id="app">
    <!-- Upload Zone -->
    <div id="upload-zone" class="upload-zone p-12 text-center cursor-pointer">
      <div class="flex flex-col items-center gap-4">
        <svg class="w-12 h-12 text-neutral-500" viewBox="0 0 48 48" fill="none">
          <path d="M24 32V16m0 0l-6 6m6-6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="8" y="8" width="32" height="32" rx="4" stroke="currentColor" stroke-width="2"/>
        </svg>
        <p class="body-md text-neutral-600">Drag & drop bank statement file here, or <span class="text-blue-600 font-medium">browse</span></p>
        <p class="body-sm text-neutral-500">Supports .qfx, .ofx, .csv, .pdf files</p>
      </div>
      <input type="file" id="file-input" accept=".qfx,.ofx,.csv,.pdf" class="hidden" />
    </div>

    <!-- Format Badge -->
    <div id="format-badge" class="hidden mt-4 flex items-center gap-2">
      <span class="caption-mono px-3 py-1 rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-200">Detected: <span id="format-label"></span></span>
    </div>

    <!-- Controls -->
    <div id="controls" class="hidden mt-6">
      <div class="flex items-center gap-4">
        <button id="download-csv" class="btn-primary">Download Standardized CSV</button>
      </div>
    </div>

    <!-- Preview Table -->
    <div id="preview" class="hidden mt-8 overflow-x-auto">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mb-4">Transaction Preview</h2>
      <p id="summary" class="body-sm text-neutral-600 dark:text-neutral-400 mb-4"></p>
      <table id="preview-table" class="w-full border-collapse">
        <thead id="table-head"></thead>
        <tbody id="table-body"></tbody>
      </table>
    </div>

    <!-- Error -->
    <div id="error" class="hidden mt-6 p-4 bg-red-50 dark:bg-red-900/30 rounded-lg">
      <p id="error-text" class="body-sm text-red-600 dark:text-red-400"></p>
    </div>
  </div>
</ToolLayout>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Use Bank Statement Parser</h2>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Upload or drag & drop any bank statement file — QFX, OFX, CSV, or PDF.</li>
        <li>The tool auto-detects the format and parses all transactions instantly.</li>
        <li>Review transactions and download standardized CSV for analysis.</li>
      </ol>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li><strong>Multi-Format Support</strong> - handles QFX, OFX, CSV, and PDF bank statement files.</li>
        <li><strong>Auto-Format Detection</strong> - instantly identifies file type by extension and content inspection.</li>
        <li><strong>Standardized Output</strong> - normalizes all formats into uniform Date, Amount, Type, Description columns.</li>
        <li><strong>Private & Secure</strong> - all processing happens in your browser. No data ever leaves your device.</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use Our Bank Statement Parser</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Dealing with different bank export formats can be frustrating. QFX, OFX, CSV, and PDF statements each have their own structure, making it hard to get a unified view of your finances. Our bank statement parser automatically detects any format you throw at it and normalizes every transaction into a clean, standardized CSV. Whether you are reconciling accounts, building a budget, or preparing tax documents, this tool eliminates the manual work of reformatting — and keeps your sensitive financial data private on your own device.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">What file formats are supported?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">The parser supports QFX (Quicken Financial Exchange), OFX (Open Financial Exchange), CSV (comma-separated values), and PDF bank statement files. Each format is detected automatically, and transactions are normalized into a standard structure.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">How does format detection work?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">The tool first checks the file extension, then inspects the file content — QFX/OFX files contain SGML tags like &lt;STMTTRN&gt;, CSV files have delimiters such as commas or tabs, and PDF files start with a %PDF header. This multi-layered detection ensures accurate format identification.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is my data secure?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Absolutely. All processing is done locally in your browser using JavaScript. Your bank statements and financial data never leave your device, ensuring complete privacy and security.</p></div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">Related Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-4">
        <a href="/finance/qfx-to-excel/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">QFX to Excel</a>
        <a href="/finance/ofx-to-excel/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">OFX to Excel</a>
        <a href="/finance/csv-to-excel/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">CSV to Excel</a>
        <a href="/finance/pdf-statement-to-excel/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">PDF to Excel</a>
        <a href="/finance/column-mapper/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">Column Mapper</a>
      </div>
    </section>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What file formats are supported?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The parser supports QFX (Quicken Financial Exchange), OFX (Open Financial Exchange), CSV (comma-separated values), and PDF bank statement files."
        }
      },
      {
        "@type": "Question",
        "name": "How does format detection work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tool first checks the file extension, then inspects the file content — QFX/OFX files contain SGML tags like STMTTRN, CSV files have delimiters such as commas or tabs, and PDF files start with a PDF header."
        }
      },
      {
        "@type": "Question",
        "name": "Is my data secure?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. All processing is done locally in your browser using JavaScript. Your bank statements and financial data never leave your device."
        }
      }
    ]
  }
  </script>

<style>
  #preview-table th {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    background: var(--color-canvas-soft-2);
    padding: 8px 12px;
    text-align: left;
    border-bottom: 1px solid var(--color-hairline);
  }
  #preview-table td {
    font-size: 14px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-hairline);
  }
  #preview-table tr:hover td {
    background: var(--color-canvas-soft);
  }
</style>

<script>
  const uploadZone = document.getElementById('upload-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const formatBadge = document.getElementById('format-badge')!;
  const formatLabel = document.getElementById('format-label')!;
  const controls = document.getElementById('controls')!;
  const downloadBtn = document.getElementById('download-csv')!;
  const preview = document.getElementById('preview')!;
  const summary = document.getElementById('summary')!;
  const tableHead = document.getElementById('table-head')!;
  const tableBody = document.getElementById('table-body')!;
  const errorDiv = document.getElementById('error')!;
  const errorText = document.getElementById('error-text')!;

  interface Transaction {
    Date: string;
    Amount: string;
    Type: string;
    Description: string;
  }

  type DetectedFormat = 'qfx' | 'ofx' | 'csv' | 'pdf' | 'unknown';

  let transactions: Transaction[] = [];
  let detectedFormat: DetectedFormat = 'unknown';

  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('dragover'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    if (e.dataTransfer?.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) handleFile(fileInput.files[0]); });

  // ---- Format Detection ----

  function detectFormat(file: File, firstChunk: string): DetectedFormat {
    const ext = file.name.split('.').pop()?.toLowerCase() || '';

    // Check extension first
    if (ext === 'qfx') return 'qfx';
    if (ext === 'ofx') return 'ofx';

    // Content inspection
    const upper = firstChunk.slice(0, 2000);
    if (upper.includes('<OFX>') || upper.includes('<STMTTRN>') || /OFXHEADER/i.test(upper)) {
      return upper.includes('CHECKNUM') || ext === 'qfx' ? 'qfx' : 'ofx';
    }
    if (upper.startsWith('%PDF')) return 'pdf';

    // CSV detection: check for delimiters
    if (ext === 'csv' || detectCSVDelimiter(upper) !== null) return 'csv';

    return 'unknown';
  }

  function detectCSVDelimiter(text: string): string | null {
    const lines = text.split('\n').slice(0, 10).filter(l => l.trim());
    if (lines.length < 2) return null;
    const candidates = [',', ';', '\t', '|'];
    let best: string | null = null;
    let bestScore = 0;
    for (const d of candidates) {
      const counts = lines.map(l => (l.match(new RegExp(d === '\t' ? '\\t' : d === '|' ? '\\|' : d, 'g')) || []).length);
      const avg = counts.reduce((a, b) => a + b, 0) / counts.length;
      const consistent = counts.every(c => c > 0 && Math.abs(c - avg) <= 1);
      if (avg > bestScore && consistent) {
        bestScore = avg;
        best = d;
      }
    }
    return best;
  }

  const FORMAT_LABELS: Record<DetectedFormat, string> = {
    qfx: 'QFX',
    ofx: 'OFX',
    csv: 'CSV',
    pdf: 'PDF',
    unknown: 'Unknown',
  };

  // ---- Main Handler ----

  async function handleFile(file: File) {
    try {
      detectedFormat = 'unknown';

      if (file.name.toLowerCase().endsWith('.pdf')) {
        detectedFormat = 'pdf';
        showBadge();
        await handlePDF(file);
        return;
      }

      const text = await file.text();

      detectedFormat = detectFormat(file, text);
      showBadge();

      if (detectedFormat === 'unknown') {
        throw new Error('Unable to detect file format. Please ensure the file is a valid QFX, OFX, CSV, or PDF bank statement.');
      }

      if (detectedFormat === 'qfx' || detectedFormat === 'ofx') {
        transactions = parseQFXOFX(text);
      } else if (detectedFormat === 'csv') {
        transactions = parseCSVTransactions(text);
      }

      if (transactions.length === 0) {
        throw new Error('No transactions found in the file. The file may not contain standard transaction data.');
      }

      renderTable();
      controls.classList.remove('hidden');
      preview.classList.remove('hidden');
      errorDiv.classList.add('hidden');
    } catch (err) {
      errorDiv.classList.remove('hidden');
      errorText.textContent = (err as Error).message;
      controls.classList.add('hidden');
      preview.classList.add('hidden');
    }
  }

  function showBadge() {
    formatLabel.textContent = FORMAT_LABELS[detectedFormat];
    formatBadge.classList.remove('hidden');
  }

  // ---- QFX / OFX Parser ----

  function parseQFXOFX(text: string): Transaction[] {
    const results: Transaction[] = [];
    const stmtTrnRegex = /<STMTTRN>([\s\S]*?)<\/STMTTRN>/gi;
    let match;

    while ((match = stmtTrnRegex.exec(text)) !== null) {
      const block = match[1];
      const date = formatOFXDate(extractTag(block, 'DTPOSTED') || extractTag(block, 'DTUSER'));
      const rawAmount = extractTag(block, 'TRNAMT');
      const type = extractTag(block, 'TRNTYPE');
      const name = extractTag(block, 'NAME');
      const memo = extractTag(block, 'MEMO');
      const desc = [name, memo].filter(Boolean).join(' - ');
      results.push({
        Date: date,
        Amount: rawAmount,
        Type: type,
        Description: desc || name || memo || '',
      });
    }

    return results;
  }

  function extractTag(block: string, tag: string): string {
    const regex = new RegExp(`<${tag}>([^<\\n\\r]+)`, 'i');
    const match = block.match(regex);
    return match ? match[1].trim() : '';
  }

  function formatOFXDate(dateStr: string): string {
    if (dateStr.length >= 8) {
      const year = dateStr.substring(0, 4);
      const month = dateStr.substring(4, 6);
      const day = dateStr.substring(6, 8);
      return `${year}-${month}-${day}`;
    }
    return dateStr;
  }

  // ---- CSV Parser ----

  function parseCSVTransactions(text: string): Transaction[] {
    const delimiter = detectCSVDelimiter(text) || ',';
    const rows = parseCSVRows(text, delimiter);

    if (rows.length < 2) return [];

    // Try to identify columns from header
    const header = rows[0].map(h => h.trim().toLowerCase());
    const colMap = {
      date: -1,
      amount: -1,
      type: -1,
      description: -1,
    };

    const dateKeywords = /\b(date|posted|trans.?date|transaction|dt)\b/i;
    const amountKeywords = /\b(amount|sum|value|trnamt|credit|debit|debet)\b/i;
    const typeKeywords = /\b(type|trntype|category|transaction.?type)\b/i;
    const descKeywords = /\b(description|memo|name|payee|narrative|details|memo\b|\bdescr)\b/i;

    header.forEach((h, i) => {
      if (colMap.date === -1 && dateKeywords.test(h)) colMap.date = i;
      if (colMap.amount === -1 && amountKeywords.test(h)) colMap.amount = i;
      if (colMap.type === -1 && typeKeywords.test(h)) colMap.type = i;
      if (colMap.description === -1 && descKeywords.test(h)) colMap.description = i;
    });

    // Fallback: if no header match, try positional guessing
    if (colMap.date === -1 && colMap.amount === -1) {
      // Heuristic: scan data rows for patterns
      const sampleRows = rows.slice(1, 10);
      // Date patterns
      const datePat = /\d{2,4}[\-\/\.]\d{1,2}[\-\/\.]\d{2,4}/;
      const amountPat = /^[-+]?\d+[.,]\d{2}$/;

      for (let col = 0; col < (rows[0]?.length || 0); col++) {
        const dateMatches = sampleRows.filter(r => r[col] && datePat.test(r[col]));
        const amountMatches = sampleRows.filter(r => r[col] && amountPat.test(r[col].trim()));

        if (dateMatches.length >= sampleRows.length * 0.5 && colMap.date === -1) {
          colMap.date = col;
        }
        if (amountMatches.length >= sampleRows.length * 0.5 && colMap.amount === -1 && col !== colMap.date) {
          colMap.amount = col;
        }
      }
    }

    // Fallback: basic column mapping by position
    if (colMap.date === -1) colMap.date = 0;
    if (colMap.amount === -1) colMap.amount = Math.min(1, rows[0].length - 1);
    if (colMap.description === -1) {
      // Pick a column that isn't date, amount, or type
      for (let i = 0; i < rows[0].length; i++) {
        if (i !== colMap.date && i !== colMap.amount && i !== colMap.type) {
          colMap.description = i;
          break;
        }
      }
    }

    const results: Transaction[] = [];
    const dataRows = header.some(h => dateKeywords.test(h)) ? rows.slice(1) : rows;

    for (const row of dataRows) {
      const date = row[colMap.date]?.trim() || '';
      const amount = row[colMap.amount]?.trim() || '';
      const type = colMap.type >= 0 ? (row[colMap.type]?.trim() || '') : '';
      const desc = colMap.description >= 0 ? (row[colMap.description]?.trim() || '') : '';
      if (!date && !amount) continue;
      results.push({
        Date: date,
        Amount: amount,
        Type: type,
        Description: desc,
      });
    }

    return results;
  }

  function parseCSVRows(text: string, delimiter: string): string[][] {
    const rows: string[][] = [];
    let current = '';
    let inQuotes = false;
    let row: string[] = [];

    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      const next = text[i + 1];

      if (char === '"') {
        if (inQuotes && next === '"') {
          current += '"';
          i++;
        } else {
          inQuotes = !inQuotes;
        }
      } else if (char === delimiter && !inQuotes) {
        row.push(current);
        current = '';
      } else if ((char === '\n' || (char === '\r' && next === '\n')) && !inQuotes) {
        row.push(current);
        current = '';
        if (row.some(cell => cell.trim() !== '')) rows.push(row);
        row = [];
        if (char === '\r') i++;
      } else {
        current += char;
      }
    }
    row.push(current);
    if (row.some(cell => cell.trim() !== '')) rows.push(row);

    return rows;
  }

  // ---- PDF Parser ----

  async function handlePDF(file: File) {
    try {
      const pdfjsLib = await loadPDFJS();
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;

      let fullText = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        fullText += content.items.map((item: any) => item.str).join(' ') + '\n';
      }

      transactions = parsePDFTransactions(fullText);

      if (transactions.length === 0) {
        throw new Error('No transactions could be extracted from this PDF. The format may not be supported.');
      }

      renderTable();
      controls.classList.remove('hidden');
      preview.classList.remove('hidden');
      errorDiv.classList.add('hidden');
    } catch (err) {
      errorDiv.classList.remove('hidden');
      errorText.textContent = (err as Error).message;
      controls.classList.add('hidden');
      preview.classList.add('hidden');
    }
  }

  function parsePDFTransactions(text: string): Transaction[] {
    const results: Transaction[] = [];
    const lines = text.split('\n').map(l => l.trim()).filter(Boolean);

    // Common date patterns in statements: MM/DD/YYYY, DD/MM/YYYY, YYYY-MM-DD, etc.
    const datePattern = /\b(\d{1,2}[\/\-\.]\d{1,2}[\/\-\.]\d{2,4})\b/;
    const amountPattern = /[-+]?\d{1,3}(?:[, ]?\d{3})*(?:\.\d{2})/;

    let i = 0;
    while (i < lines.length) {
      const line = lines[i];
      const dateMatch = line.match(datePattern);
      if (dateMatch && line.length < 200) {
        // Find amounts in this line
        const amounts = [...line.matchAll(new RegExp(amountPattern, 'g'))];
        if (amounts.length > 0) {
          // Try to extract description from between date and first amount, or after last amount
          const dateEnd = (dateMatch.index || 0) + dateMatch[0].length;
          const firstAmtIdx = amounts[0].index || 0;
          const lastAmtEnd = (amounts[amounts.length - 1].index || 0) + amounts[amounts.length - 1][0].length;

          let description = line.slice(dateEnd, Math.min(firstAmtIdx, line.length)).trim();
          if (!description && lastAmtEnd < line.length) {
            description = line.slice(lastAmtEnd).trim();
          }
          if (!description) {
            description = line;
          }

          // Use the last amount as the transaction amount (often debit at end, credit could be earlier)
          const rawAmount = amounts[amounts.length - 1][0];
          const cleanAmount = rawAmount.replace(/[, ]/g, '');

          results.push({
            Date: dateMatch[0],
            Amount: cleanAmount,
            Type: '',
            Description: description.replace(datePattern, '').replace(new RegExp(amountPattern, 'g'), '').trim().replace(/\s+/g, ' ') || description,
          });
        }
      }
      i++;
    }

    return results;
  }

  async function loadPDFJS(): Promise<any> {
    return new Promise((resolve, reject) => {
      if ((window as any).pdfjsLib) {
        resolve((window as any).pdfjsLib);
        return;
      }
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
      script.onload = () => resolve((window as any).pdfjsLib);
      script.onerror = () => reject(new Error('Failed to load PDF parser. Please check your internet connection and try again.'));
      document.head.appendChild(script);
    });
  }

  // ---- Rendering ----

  function renderTable() {
    const headers = ['Date', 'Amount', 'Type', 'Description'];
    tableHead.innerHTML = `<tr>${headers.map(h => `<th>${h}</th>`).join('')}</tr>`;
    tableBody.innerHTML = transactions.slice(0, 100).map(t => {
      const amount = parseFloat(t.Amount);
      const isNegative = !isNaN(amount) && amount < 0;
      return `<tr>
        <td>${t.Date}</td>
        <td class="${isNegative ? 'text-red-600' : 'text-blue-600'}">${t.Amount}</td>
        <td>${t.Type}</td>
        <td>${escapeHtml(t.Description)}</td>
      </tr>`;
    }).join('');
    summary.textContent = `Found ${transactions.length} transaction(s)`;
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // ---- Download ----

  function toCSV(): string {
    const headers = 'Date,Amount,Type,Description';
    const rows = transactions.map(t =>
      `"${t.Date}","${t.Amount}","${t.Type}","${t.Description.replace(/"/g, '""')}"`
    );
    return [headers, ...rows].join('\n');
  }

  function downloadFile(content: string, filename: string, mime: string) {
    const blob = new Blob([content], { type: mime });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = filename;
    link.click();
  }

  downloadBtn.addEventListener('click', () => {
    downloadFile(toCSV(), 'standardized-transactions.csv', 'text/csv');
  });
</script>
