---
/**
 * OFX to Excel/CSV Converter
 * Parses OFX (Open Financial Exchange) XML using DOMParser.
 * Generates downloadable CSV/Excel-compatible output.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="OFX to Excel"
  metaTitle="OFX to Excel Converter Free - Bank Statement to XLSX | Woorkeasy"
  description="Convert OFX bank statements to Excel online free. Transform financial OFX files into editable XLSX spreadsheets. No upload, secure processing."
  heading="Convert OFX to Excel"
  category="Finance"
>
  <div id="ofx-app">
    <!-- Upload Zone -->
    <div id="upload-zone" class="upload-zone p-12 text-center cursor-pointer">
      <div class="flex flex-col items-center gap-4">
        <svg class="w-12 h-12 text-neutral-500" viewBox="0 0 48 48" fill="none">
          <path d="M24 32V16m0 0l-6 6m6-6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="8" y="8" width="32" height="32" rx="4" stroke="currentColor" stroke-width="2"/>
        </svg>
        <p class="body-md text-neutral-600">Drag & drop OFX file here, or <span class="text-blue-600 font-medium">browse</span></p>
        <p class="body-sm text-neutral-500">Supports .ofx files from banks</p>
      </div>
      <input type="file" id="file-input" accept=".ofx" class="hidden" />
    </div>

    <!-- Controls -->
    <div id="controls" class="hidden mt-6">
      <div class="flex items-center gap-4">
        <button id="download-csv" class="btn-primary">Download CSV</button>
        <button id="download-excel" class="btn-secondary">Download Excel (TSV)</button>
      </div>
    </div>

    <!-- Preview Table -->
    <div id="preview" class="hidden mt-8 overflow-x-auto">
      <h2 class="display-sm text-neutral-900 mb-4">Transaction Preview</h2>
      <table id="preview-table" class="w-full border-collapse">
        <thead id="table-head"></thead>
        <tbody id="table-body"></tbody>
      </table>
    </div>

    <!-- Error -->
    <div id="error" class="hidden mt-6 p-4 bg-red-50 rounded-lg">
      <p id="error-text" class="body-sm text-red-600"></p>
    </div>
  </div>
</ToolLayout>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Use OFX to Excel Converter</h2>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Upload or drag & drop your OFX bank statement file onto the converter.</li>
        <li>Review the parsed transactions in the preview table to verify accuracy.</li>
        <li>Download as CSV or Excel (TSV) for further analysis in your spreadsheet software.</li>
      </ol>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li><strong>Bank Transaction Parsing</strong> - extracts date, amount, type, name, and memo from OFX statements.</li>
        <li><strong>Dual Export</strong> - download as CSV (comma-separated) or TSV (opens directly in Excel).</li>
        <li><strong>Transaction Preview</strong> - review all parsed entries before downloading.</li>
        <li><strong>Secure & Private</strong> - all processing runs locally. Your financial data never leaves your device.</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use Our OFX to Excel Converter</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Managing personal or business finances often requires importing bank statement data into spreadsheet software. Our OFX to Excel converter parses your bank's OFX export files and transforms transaction data into clean, editable spreadsheets. No more manual data entry or sending sensitive financial information to cloud servers. The built-in preview lets you verify all transactions before downloading, ensuring accuracy every time.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Which banks support OFX exports?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Most major banks and financial institutions support OFX export, including Chase, Bank of America, Wells Fargo, Citibank, and many others. Check your bank's download options for QFX, OFX, or Quicken format.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I convert multiple OFX files?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">You can process one file at a time. Simply upload each OFX file separately to convert them. Each file's transactions will be parsed and displayed in the preview table.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is my financial data secure?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Yes, all processing is done locally in your browser using JavaScript. Your bank statements and transaction data never leave your computer, ensuring complete privacy and security.</p></div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">Related Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-4">
        <a href="/finance/qfx-to-excel/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">QFX to Excel</a>
        <a href="/finance/csv-to-excel/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">CSV to Excel</a>
        <a href="/finance/excel-to-csv/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">Excel to CSV</a>
        <a href="/finance/csv-cleaner/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">CSV Cleaner</a>
        <a href="/finance/csv-formatter/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">CSV Formatter</a>
        <a href="/finance/bank-statement-parser/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">Bank Statement Parser</a>
      </div>
    </section>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Which banks support OFX exports?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most major banks and financial institutions support OFX export, including Chase, Bank of America, Wells Fargo, Citibank, and many others."
        }
      },
      {
        "@type": "Question",
        "name": "Can I convert multiple OFX files?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can process one file at a time. Simply upload each OFX file separately to convert them."
        }
      },
      {
        "@type": "Question",
        "name": "Is my financial data secure?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, all processing is done locally in your browser using JavaScript. Your bank statements and transaction data never leave your computer."
        }
      }
    ]
  }
  </script>

<style>
  #preview-table th {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    background: var(--color-canvas-soft-2);
    padding: 8px 12px;
    text-align: left;
    border-bottom: 1px solid var(--color-hairline);
  }
  #preview-table td {
    font-size: 14px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-hairline);
  }
</style>

<script>
  const uploadZone = document.getElementById('upload-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const controls = document.getElementById('controls')!;
  const downloadCSV = document.getElementById('download-csv')!;
  const downloadExcel = document.getElementById('download-excel')!;
  const preview = document.getElementById('preview')!;
  const tableHead = document.getElementById('table-head')!;
  const tableBody = document.getElementById('table-body')!;
  const errorDiv = document.getElementById('error')!;
  const errorText = document.getElementById('error-text')!;

  interface Transaction {
    date: string;
    amount: string;
    type: string;
    name: string;
    memo: string;
    fitid: string;
  }

  let transactions: Transaction[] = [];

  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('dragover'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    if (e.dataTransfer?.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) handleFile(fileInput.files[0]); });

  async function handleFile(file: File) {
    try {
      const text = await file.text();
      transactions = parseOFX(text);

      if (transactions.length === 0) {
        throw new Error('No transactions found in file');
      }

      renderTable();
      controls.classList.remove('hidden');
      preview.classList.remove('hidden');
      errorDiv.classList.add('hidden');
    } catch (err) {
      errorDiv.classList.remove('hidden');
      errorText.textContent = (err as Error).message;
      controls.classList.add('hidden');
      preview.classList.add('hidden');
    }
  }

  function parseOFX(text: string): Transaction[] {
    // OFX can be SGML (not well-formed XML), so we do manual parsing
    const results: Transaction[] = [];
    const stmtTrnRegex = /<STMTTRN>([\s\S]*?)<\/STMTTRN>/gi;
    let match;

    while ((match = stmtTrnRegex.exec(text)) !== null) {
      const block = match[1];
      results.push({
        date: formatOFXDate(extractTag(block, 'DTPOSTED')),
        amount: extractTag(block, 'TRNAMT'),
        type: extractTag(block, 'TRNTYPE'),
        name: extractTag(block, 'NAME'),
        memo: extractTag(block, 'MEMO'),
        fitid: extractTag(block, 'FITID'),
      });
    }

    return results;
  }

  function extractTag(block: string, tag: string): string {
    const regex = new RegExp(`<${tag}>([^<\\n]+)`, 'i');
    const match = block.match(regex);
    return match ? match[1].trim() : '';
  }

  function formatOFXDate(dateStr: string): string {
    if (dateStr.length >= 8) {
      const year = dateStr.substring(0, 4);
      const month = dateStr.substring(4, 6);
      const day = dateStr.substring(6, 8);
      return `${year}-${month}-${day}`;
    }
    return dateStr;
  }

  function renderTable() {
    const headers = ['Date', 'Amount', 'Type', 'Name', 'Memo'];
    tableHead.innerHTML = `<tr>${headers.map(h => `<th>${h}</th>`).join('')}</tr>`;
    tableBody.innerHTML = transactions.slice(0, 50).map(t => `
      <tr>
        <td>${t.date}</td>
        <td>${t.amount}</td>
        <td>${t.type}</td>
        <td>${t.name}</td>
        <td>${t.memo}</td>
      </tr>
    `).join('');
  }

  function toCSV(): string {
    const headers = 'Date,Amount,Type,Name,Memo,FITID';
    const rows = transactions.map(t =>
      `"${t.date}","${t.amount}","${t.type}","${t.name.replace(/"/g, '""')}","${t.memo.replace(/"/g, '""')}","${t.fitid}"`
    );
    return [headers, ...rows].join('\n');
  }

  function toTSV(): string {
    const headers = 'Date\tAmount\tType\tName\tMemo\tFITID';
    const rows = transactions.map(t =>
      `${t.date}\t${t.amount}\t${t.type}\t${t.name}\t${t.memo}\t${t.fitid}`
    );
    return [headers, ...rows].join('\n');
  }

  function downloadFile(content: string, filename: string, mime: string) {
    const blob = new Blob([content], { type: mime });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = filename;
    link.click();
  }

  downloadCSV.addEventListener('click', () => {
    downloadFile(toCSV(), 'transactions.csv', 'text/csv');
  });

  downloadExcel.addEventListener('click', () => {
    // TSV opens directly in Excel
    downloadFile(toTSV(), 'transactions.xls', 'application/vnd.ms-excel');
  });
</script>




