---
/**
 * OFX to Excel/CSV Converter
 * Parses OFX (Open Financial Exchange) XML using DOMParser.
 * Generates downloadable CSV/Excel-compatible output.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="OFX to Excel"
  metaTitle="OFX to Excel Converter Free - Bank Statement to XLSX | Woorkeasy"
  description="Convert OFX bank statements to Excel online free. Transform financial OFX files into editable XLSX spreadsheets. No upload, secure processing."
  heading="Convert OFX to Excel"
  category="Finance"
  tryNextTools={[
    { name: 'QFX to Excel', href: '/finance/qfx-to-excel/' },
    { name: 'Bank Statement Parser', href: '/finance/bank-statement-parser/' },
    { name: 'CSV Cleaner', href: '/finance/csv-cleaner/' },
    { name: 'Merge PDF', href: '/pdf/merge-pdf/' },
  ]}
>
  <div id="ofx-app">
    <!-- Upload Zone -->
    <div id="upload-zone" class="upload-zone p-12 text-center cursor-pointer">
      <div class="flex flex-col items-center gap-4">
        <svg class="w-12 h-12 text-neutral-500" viewBox="0 0 48 48" fill="none">
          <path d="M24 32V16m0 0l-6 6m6-6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="8" y="8" width="32" height="32" rx="4" stroke="currentColor" stroke-width="2"/>
        </svg>
        <p class="body-md text-neutral-600">Drag & drop OFX file here, or <span class="text-blue-600 font-medium">browse</span></p>
        <p class="body-sm text-neutral-500">Supports .ofx files from banks</p>
      </div>
      <input type="file" id="file-input" accept=".ofx" class="hidden" />
    </div>

    <!-- Controls -->
    <div id="controls" class="hidden mt-6">
      <div class="flex items-center gap-4">
        <button id="download-csv" class="btn-primary">Download CSV</button>
        <button id="download-excel" class="btn-secondary">Download Excel (TSV)</button>
      </div>
    </div>

    <!-- Preview Table -->
    <div id="preview" class="hidden mt-8 overflow-x-auto">
      <h2 class="display-sm text-neutral-900 mb-4">Transaction Preview</h2>
      <table id="preview-table" class="w-full border-collapse">
        <thead id="table-head"></thead>
        <tbody id="table-body"></tbody>
      </table>
    </div>

    <!-- Error -->
    <div id="error" class="hidden mt-6 p-4 bg-red-50 rounded-lg">
      <p id="error-text" class="body-sm text-red-600"></p>
    </div>
  </div>
</ToolLayout>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Convert OFX to Excel</h2>
      <p class="body-md text-neutral-600 dark:text-neutral-400 mt-2">Converting OFX bank statements to Excel spreadsheets takes just three steps:</p>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Upload or drag & drop your OFX bank statement file onto the converter above.</li>
        <li>Review the parsed transactions in the preview table to verify all entries are correct.</li>
        <li>Download as CSV or Excel (TSV) for further analysis in Microsoft Excel, Google Sheets, or any spreadsheet software.</li>
      </ol>
      <p class="body-md text-neutral-600 dark:text-neutral-400 mt-4">The entire conversion happens in your browser with no server upload, keeping your financial data private and secure.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li><strong>OFX Transaction Parsing</strong> - automatically extracts date, amount, transaction type, payee name, and memo from OFX statement files.</li>
        <li><strong>Dual Format Export</strong> - download your transactions as CSV for general use or TSV format that opens directly in Microsoft Excel with proper column alignment.</li>
        <li><strong>Transaction Preview</strong> - review all parsed entries in a clear table before downloading, so you can verify accuracy ahead of time.</li>
        <li><strong>Zero Server Upload</strong> - every byte of your bank statement is processed locally in your browser. Your financial data never touches any server.</li>
        <li><strong>Free & Unlimited</strong> - no account creation, no subscription fees, no file size limits. Use it as many times as you need.</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use an Online OFX to Excel Converter</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">OFX (Open Financial Exchange) is a standard format used by banks and financial institutions to export transaction data. While OFX files are excellent for data portability, they are not human-readable and cannot be opened directly in spreadsheet applications like Microsoft Excel or Google Sheets. This is where an OFX to Excel converter becomes indispensable for anyone managing personal or business finances.</p>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Accountants, bookkeepers, and small business owners frequently need to analyze bank transactions for reconciliation, budgeting, tax preparation, and financial reporting. Manually copying transaction data from bank statements into spreadsheets is time-consuming, error-prone, and impractical for accounts with hundreds of monthly transactions. Our browser-based converter eliminates this busywork by parsing the structured OFX data and delivering it in a clean, editable spreadsheet format within seconds.</p>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Financial data privacy is a major concern when using online tools. Unlike cloud-based services that require uploading sensitive bank statements to remote servers, our OFX to Excel converter runs entirely in your browser using client-side JavaScript. Your transaction data never leaves your computer, eliminating the risk of data breaches or unauthorized access. This makes it ideal for processing confidential financial documents securely.</p>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">The converter handles OFX files from virtually any bank that supports the Open Financial Exchange standard, including Chase, Bank of America, Wells Fargo, Citibank, US Bank, PNC, and hundreds of credit unions. Whether you need to convert monthly statements for personal budget tracking or process bulk financial data for business accounting, this tool delivers accurate, reliable results without any software installation.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">What is an OFX file and how do I get one from my bank?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">OFX (Open Financial Exchange) is a standardized file format for financial data exchange. Most banks allow you to download your transaction history as an OFX file from their online banking portal, usually under "Download Transactions," "Export," or "Statements" sections. Look for options labeled OFX, QFX, Quicken, or Microsoft Money format.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">What is the difference between OFX and QFX files?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">OFX is the open standard format, while QFX is Quicken's proprietary variant. Both contain the same transaction data structure. Our converter handles OFX files, and if you have a QFX file, use our QFX to Excel converter instead.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I convert multiple OFX files at once?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">You can process one file at a time. Simply upload each OFX file separately to convert them. Each file's transactions will be parsed and displayed in the preview table for verification before downloading.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is my financial data secure when using this converter?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Absolutely. All processing happens locally in your browser using JavaScript. Your OFX bank statements and transaction data never leave your computer, are never uploaded to any server, and are not stored anywhere. Complete privacy is guaranteed.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Which banks support OFX file export?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Most major banks and financial institutions support OFX export, including Chase, Bank of America, Wells Fargo, Citibank, US Bank, PNC, Capital One, and thousands of credit unions. Check your bank's download or export options for OFX, QFX, or Quicken format.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I open the downloaded file in Microsoft Excel?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Yes. Download as TSV format to open directly in Excel with proper column layout, or download as CSV and open in Excel, Google Sheets, or any spreadsheet application. Both formats preserve all transaction data including date, amount, type, payee name, and memo.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is there a file size limit for OFX files?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">No artificial limits exist. Since processing happens locally in your browser, the practical limit depends on your device memory. Most OFX files are under 5MB, and the converter handles them instantly.</p></div>
      </div>
    </section>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is an OFX file and how do I get one from my bank?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "OFX (Open Financial Exchange) is a standardized file format for financial data exchange. Most banks allow you to download your transaction history as an OFX file from their online banking portal."
        }
      },
      {
        "@type": "Question",
        "name": "Can I convert multiple OFX files at once?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can process one file at a time. Simply upload each OFX file separately to convert them."
        }
      },
      {
        "@type": "Question",
        "name": "Is my financial data secure?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, all processing is done locally in your browser using JavaScript. Your bank statements and transaction data never leave your computer."
        }
      },
      {
        "@type": "Question",
        "name": "Can I open the downloaded file in Microsoft Excel?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Download as TSV format to open directly in Excel with proper column layout, or download as CSV and open in Excel, Google Sheets, or any spreadsheet application."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between OFX and QFX files?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "OFX is the open standard format, while QFX is Quicken's proprietary variant. Use our QFX to Excel converter for QFX files."
        }
      },
      {
        "@type": "Question",
        "name": "Which banks support OFX file export?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most major banks support OFX export, including Chase, Bank of America, Wells Fargo, Citibank, US Bank, PNC, Capital One, and thousands of credit unions."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a file size limit for OFX files?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No artificial limits exist. Since processing happens locally in your browser, the practical limit depends on your device memory."
        }
      }
    ]
  }
  </script>

<style>
  #preview-table th {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    background: var(--color-canvas-soft-2);
    padding: 8px 12px;
    text-align: left;
    border-bottom: 1px solid var(--color-hairline);
  }
  #preview-table td {
    font-size: 14px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-hairline);
  }
</style>

<script>
  const uploadZone = document.getElementById('upload-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const controls = document.getElementById('controls')!;
  const downloadCSV = document.getElementById('download-csv')!;
  const downloadExcel = document.getElementById('download-excel')!;
  const preview = document.getElementById('preview')!;
  const tableHead = document.getElementById('table-head')!;
  const tableBody = document.getElementById('table-body')!;
  const errorDiv = document.getElementById('error')!;
  const errorText = document.getElementById('error-text')!;

  interface Transaction {
    date: string;
    amount: string;
    type: string;
    name: string;
    memo: string;
    fitid: string;
  }

  let transactions: Transaction[] = [];

  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('dragover'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    if (e.dataTransfer?.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) handleFile(fileInput.files[0]); });

  async function handleFile(file: File) {
    try {
      const text = await file.text();
      transactions = parseOFX(text);

      if (transactions.length === 0) {
        throw new Error('No transactions found in file');
      }

      renderTable();
      controls.classList.remove('hidden');
      preview.classList.remove('hidden');
      errorDiv.classList.add('hidden');
    } catch (err) {
      errorDiv.classList.remove('hidden');
      errorText.textContent = (err as Error).message;
      controls.classList.add('hidden');
      preview.classList.add('hidden');
    }
  }

  function parseOFX(text: string): Transaction[] {
    // OFX can be SGML (not well-formed XML), so we do manual parsing
    const results: Transaction[] = [];
    const stmtTrnRegex = /<STMTTRN>([\s\S]*?)<\/STMTTRN>/gi;
    let match;

    while ((match = stmtTrnRegex.exec(text)) !== null) {
      const block = match[1];
      results.push({
        date: formatOFXDate(extractTag(block, 'DTPOSTED')),
        amount: extractTag(block, 'TRNAMT'),
        type: extractTag(block, 'TRNTYPE'),
        name: extractTag(block, 'NAME'),
        memo: extractTag(block, 'MEMO'),
        fitid: extractTag(block, 'FITID'),
      });
    }

    return results;
  }

  function extractTag(block: string, tag: string): string {
    const regex = new RegExp(`<${tag}>([^<\\n]+)`, 'i');
    const match = block.match(regex);
    return match ? match[1].trim() : '';
  }

  function formatOFXDate(dateStr: string): string {
    if (dateStr.length >= 8) {
      const year = dateStr.substring(0, 4);
      const month = dateStr.substring(4, 6);
      const day = dateStr.substring(6, 8);
      return `${year}-${month}-${day}`;
    }
    return dateStr;
  }

  function renderTable() {
    const headers = ['Date', 'Amount', 'Type', 'Name', 'Memo'];
    tableHead.innerHTML = `<tr>${headers.map(h => `<th>${h}</th>`).join('')}</tr>`;
    tableBody.innerHTML = transactions.slice(0, 50).map(t => `
      <tr>
        <td>${t.date}</td>
        <td>${t.amount}</td>
        <td>${t.type}</td>
        <td>${t.name}</td>
        <td>${t.memo}</td>
      </tr>
    `).join('');
  }

  function toCSV(): string {
    const headers = 'Date,Amount,Type,Name,Memo,FITID';
    const rows = transactions.map(t =>
      `"${t.date}","${t.amount}","${t.type}","${t.name.replace(/"/g, '""')}","${t.memo.replace(/"/g, '""')}","${t.fitid}"`
    );
    return [headers, ...rows].join('\n');
  }

  function toTSV(): string {
    const headers = 'Date\tAmount\tType\tName\tMemo\tFITID';
    const rows = transactions.map(t =>
      `${t.date}\t${t.amount}\t${t.type}\t${t.name}\t${t.memo}\t${t.fitid}`
    );
    return [headers, ...rows].join('\n');
  }

  function downloadFile(content: string, filename: string, mime: string) {
    const blob = new Blob([content], { type: mime });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = filename;
    link.click();
  }

  downloadCSV.addEventListener('click', () => {
    downloadFile(toCSV(), 'transactions.csv', 'text/csv');
  });

  downloadExcel.addEventListener('click', () => {
    // TSV opens directly in Excel
    downloadFile(toTSV(), 'transactions.xls', 'application/vnd.ms-excel');
  });
</script>




