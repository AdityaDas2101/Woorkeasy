---
/**
 * CSV to Excel Tool
 * Convert CSV files to Excel (.xlsx) format.
 * Parses CSV with proper delimiter detection and generates XLSX using a lightweight builder.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="CSV to Excel"
  metaTitle="CSV to Excel Converter Free  - CSV to XLSX Online | Woorkeasy"
  description="Convert CSV to Excel online free. Transform CSV files to proper .xlsx spreadsheets instantly. No upload, browser-based converter, 100% free."
  heading="CSV to Excel."
  category="Finance"
>
  <div id="csv-to-excel-app" class="flex flex-col gap-6">
    <!-- Upload Zone -->
    <div
      id="upload-zone"
      class="upload-zone flex flex-col items-center justify-center gap-3 p-12 border-2 border-dashed border-neutral-300 rounded-lg cursor-pointer hover:border-neutral-400 transition-colors"
    >
      <span class="text-4xl">"</span>
      <p class="body-md text-neutral-600 dark:text-neutral-400 text-center">
        Drop a CSV file here or <span class="text-neutral-900 dark:text-neutral-100 font-medium underline">browse</span>
      </p>
      <p class="body-sm text-neutral-500">Supports .csv and .tsv files</p>
      <input id="file-input" type="file" accept=".csv,.tsv,text/csv,text/tab-separated-values" class="hidden" />
    </div>

    <!-- Options -->
    <div id="options-panel" class="hidden p-4 bg-neutral-50 dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700">
      <div class="flex flex-wrap items-center gap-6">
        <div class="flex items-center gap-3">
          <label for="delimiter-select" class="body-sm font-medium text-neutral-700 dark:text-neutral-300">Delimiter:</label>
          <select id="delimiter-select" class="px-3 py-1.5 border border-neutral-200 dark:border-neutral-700 rounded-md text-sm bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:border-neutral-900">
            <option value="auto">Auto-detect</option>
            <option value=",">Comma (,)</option>
            <option value=";">Semicolon (;)</option>
            <option value="\t">Tab</option>
            <option value="|">Pipe (|)</option>
          </select>
        </div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="first-row-header" checked class="accent-neutral-900" />
          <span class="body-sm text-neutral-700 dark:text-neutral-300">First row is header</span>
        </label>
      </div>
    </div>

    <!-- File Info & Preview -->
    <div id="file-info" class="hidden">
      <div class="flex items-center gap-3 p-4 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 rounded-lg mb-4">
        <span class="text-lg">"</span>
        <div class="flex-1 min-w-0">
          <p id="file-name" class="body-sm font-medium text-neutral-900 dark:text-neutral-100 truncate"></p>
          <p id="file-stats" class="caption-mono text-neutral-500"></p>
        </div>
        <button id="clear-btn" class="text-neutral-400 hover:text-red-500 transition-colors text-lg leading-none">&times;</button>
      </div>

      <!-- Preview Table -->
      <div class="overflow-x-auto border border-neutral-200 dark:border-neutral-700 rounded-lg max-h-[300px] overflow-y-auto">
        <table id="preview-table" class="w-full text-sm text-left">
        </table>
      </div>
    </div>

    <!-- Actions -->
    <div id="action-bar" class="hidden flex flex-wrap items-center gap-3">
      <button id="convert-btn" class="btn-primary">Download as Excel (.xlsx)</button>
    </div>
  </div>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Use CSV to Excel Converter</h2>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Upload or drag & drop your CSV file onto the converter area.</li>
        <li>Select the delimiter (auto-detect, comma, semicolon, tab, or pipe) and choose whether the first row is a header.</li>
        <li>Click "Download as Excel (.xlsx)" to save your converted spreadsheet.</li>
      </ol>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li><strong>Auto-Detect Delimiter</strong> - automatically identifies comma, semicolon, tab, and pipe delimiters.</li>
        <li><strong>Live Preview</strong> - inspect your parsed data before converting to catch any issues.</li>
        <li><strong>Proper XLSX Output</strong> - generates a real .xlsx file compatible with Excel, Google Sheets, and LibreOffice.</li>
        <li><strong>100% Browser-Based</strong> - your files never leave your device. No upload, no servers, complete privacy.</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use Our CSV to Excel Converter</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Our free online CSV to Excel converter delivers instant, accurate transformations without compromising your data privacy. Unlike cloud-based alternatives, all processing happens locally in your browser so sensitive spreadsheets never leave your computer. The auto-delimiter detection handles messy CSV exports from any source, while the live preview ensures your data is parsed correctly before download. Whether you are a data analyst cleaning datasets or an office worker reformatting reports, this tool provides a fast, reliable XLSX conversion in seconds.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Can I convert large CSV files?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Yes, the converter handles large CSV files efficiently. Since everything runs in your browser, performance depends on your device's memory. For extremely large files (100k+ rows), we recommend a modern browser like Chrome or Edge.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">What delimiters are supported?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Our tool supports comma (,), semicolon (;), tab, and pipe (|) delimiters. The auto-detect feature intelligently identifies the correct delimiter from your file, so you rarely need to select it manually.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Is my data safe when converting CSV to Excel?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Absolutely. All processing is done locally in your browser using JavaScript. No files are uploaded to any server, and your data never leaves your device.</p></div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">Related Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-4">
        <a href="/finance/excel-to-csv/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">Excel to CSV</a>
        <a href="/finance/ofx-to-excel/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">OFX to Excel</a>
        <a href="/finance/qfx-to-excel/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">QFX to Excel</a>
      </div>
    </section>
  </div>
</ToolLayout>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can I convert large CSV files?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the converter handles large CSV files efficiently. Since everything runs in your browser, performance depends on your device's memory. For extremely large files (100k+ rows), we recommend a modern browser like Chrome or Edge."
        }
      },
      {
        "@type": "Question",
        "name": "What delimiters are supported?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our tool supports comma (,), semicolon (;), tab, and pipe (|) delimiters. The auto-detect feature intelligently identifies the correct delimiter from your file, so you rarely need to select it manually."
        }
      },
      {
        "@type": "Question",
        "name": "Is my data safe when converting CSV to Excel?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. All processing is done locally in your browser using JavaScript. No files are uploaded to any server, and your data never leaves your device."
        }
      }
    ]
  }
  </script>

<script>
  const uploadZone = document.getElementById('upload-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const optionsPanel = document.getElementById('options-panel')!;
  const delimiterSelect = document.getElementById('delimiter-select') as HTMLSelectElement;
  const firstRowHeader = document.getElementById('first-row-header') as HTMLInputElement;
  const fileInfo = document.getElementById('file-info')!;
  const fileNameEl = document.getElementById('file-name')!;
  const fileStats = document.getElementById('file-stats')!;
  const previewTable = document.getElementById('preview-table')!;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const actionBar = document.getElementById('action-bar')!;
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement;

  let csvContent = '';
  let parsedRows: string[][] = [];

  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('border-neutral-500'); });
  uploadZone.addEventListener('dragleave', () => { uploadZone.classList.remove('border-neutral-500'); });
  uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.classList.remove('border-neutral-500'); if (e.dataTransfer?.files[0]) loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });

  async function loadFile(file: File) {
    csvContent = await file.text();
    fileNameEl.textContent = file.name;
    parseAndPreview();
    fileInfo.classList.remove('hidden');
    optionsPanel.classList.remove('hidden');
    actionBar.classList.remove('hidden');
    uploadZone.classList.add('hidden');
  }

  delimiterSelect.addEventListener('change', parseAndPreview);
  firstRowHeader.addEventListener('change', parseAndPreview);

  function detectDelimiter(text: string): string {
    const firstLines = text.split('\n').slice(0, 5).join('\n');
    const counts: Record<string, number> = { ',': 0, ';': 0, '\t': 0, '|': 0 };
    for (const char of Object.keys(counts)) {
      counts[char] = (firstLines.match(new RegExp(char === '|' ? '\\|' : char, 'g')) || []).length;
    }
    return Object.entries(counts).sort((a, b) => b[1] - a[1])[0][0];
  }

  function parseCSV(text: string, delimiter: string): string[][] {
    const rows: string[][] = [];
    let current = '';
    let inQuotes = false;
    let row: string[] = [];

    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      const next = text[i + 1];

      if (char === '"') {
        if (inQuotes && next === '"') {
          current += '"';
          i++; // skip escaped quote
        } else {
          inQuotes = !inQuotes;
        }
      } else if (char === delimiter && !inQuotes) {
        row.push(current);
        current = '';
      } else if ((char === '\n' || (char === '\r' && next === '\n')) && !inQuotes) {
        row.push(current);
        current = '';
        if (row.some(cell => cell.trim() !== '')) rows.push(row);
        row = [];
        if (char === '\r') i++; // skip \n after \r
      } else {
        current += char;
      }
    }
    // Last row
    row.push(current);
    if (row.some(cell => cell.trim() !== '')) rows.push(row);

    return rows;
  }

  function parseAndPreview() {
    const delimiter = delimiterSelect.value === 'auto' ? detectDelimiter(csvContent) : delimiterSelect.value === '\\t' ? '\t' : delimiterSelect.value;
    parsedRows = parseCSV(csvContent, delimiter);

    const totalRows = parsedRows.length;
    const totalCols = parsedRows.reduce((max, r) => Math.max(max, r.length), 0);
    fileStats.textContent = `${totalRows} rows - ${totalCols} columns  delimiter: "${delimiter === '\t' ? 'tab' : delimiter}"`;

    // Build preview (first 20 rows)
    const hasHeader = firstRowHeader.checked;
    const previewRows = parsedRows.slice(0, 20);
    let html = '';

    if (hasHeader && previewRows.length > 0) {
      html += '<thead class="bg-neutral-100 dark:bg-neutral-800 sticky top-0"><tr>';
      previewRows[0].forEach(cell => {
        html += `<th class="px-3 py-2 font-medium text-neutral-900 dark:text-neutral-100 border-b border-neutral-200 dark:border-neutral-700 whitespace-nowrap">${escapeHtml(cell)}</th>`;
      });
      html += '</tr></thead>';
      html += '<tbody>';
      previewRows.slice(1).forEach(row => {
        html += '<tr>';
        row.forEach(cell => {
          html += `<td class="px-3 py-1.5 text-neutral-700 dark:text-neutral-300 border-b border-neutral-100 dark:border-neutral-800 whitespace-nowrap">${escapeHtml(cell)}</td>`;
        });
        html += '</tr>';
      });
      html += '</tbody>';
    } else {
      html += '<tbody>';
      previewRows.forEach(row => {
        html += '<tr>';
        row.forEach(cell => {
          html += `<td class="px-3 py-1.5 text-neutral-700 dark:text-neutral-300 border-b border-neutral-100 dark:border-neutral-800 whitespace-nowrap">${escapeHtml(cell)}</td>`;
        });
        html += '</tr>';
      });
      html += '</tbody>';
    }

    if (totalRows > 20) {
      html += `<tfoot><tr><td colspan="99" class="px-3 py-2 text-center caption-mono text-neutral-500">... and ${totalRows - 20} more rows</td></tr></tfoot>`;
    }

    previewTable.innerHTML = html;
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  clearBtn.addEventListener('click', () => {
    csvContent = '';
    parsedRows = [];
    fileInfo.classList.add('hidden');
    optionsPanel.classList.add('hidden');
    actionBar.classList.add('hidden');
    uploadZone.classList.remove('hidden');
    previewTable.innerHTML = '';
    fileInput.value = '';
  });

  // Generate XLSX (minimal Open XML format)
  convertBtn.addEventListener('click', () => {
    if (!parsedRows.length) return;

    const xlsx = buildXLSX(parsedRows);
    const blob = new Blob([xlsx], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = (fileNameEl.textContent || 'data').replace(/\.(csv|tsv)$/i, '') + '.xlsx';
    a.click();
    URL.revokeObjectURL(url);
  });

  // Minimal XLSX builder (ZIP with XML)
  function buildXLSX(rows: string[][]): Uint8Array {
    // Build shared strings and sheet data
    const sharedStrings: string[] = [];
    const ssMap = new Map<string, number>();

    function getSSIndex(str: string): number {
      if (ssMap.has(str)) return ssMap.get(str)!;
      const idx = sharedStrings.length;
      sharedStrings.push(str);
      ssMap.set(str, idx);
      return idx;
    }

    // Build sheet XML
    let sheetData = '';
    rows.forEach((row, rowIdx) => {
      sheetData += `<row r="${rowIdx + 1}">`;
      row.forEach((cell, colIdx) => {
        const ref = colToLetter(colIdx) + (rowIdx + 1);
        const num = parseFloat(cell);
        if (cell.trim() !== '' && !isNaN(num) && isFinite(num) && cell.trim() === String(num)) {
          sheetData += `<c r="${ref}"><v>${num}</v></c>`;
        } else {
          const idx = getSSIndex(cell);
          sheetData += `<c r="${ref}" t="s"><v>${idx}</v></c>`;
        }
      });
      sheetData += '</row>';
    });

    const sheetXML = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main"><sheetData>${sheetData}</sheetData></worksheet>`;

    const ssXML = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<sst xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" count="${sharedStrings.length}" uniqueCount="${sharedStrings.length}">${sharedStrings.map(s => `<si><t>${escapeXml(s)}</t></si>`).join('')}</sst>`;

    const workbookXML = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<workbook xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"><sheets><sheet name="Sheet1" sheetId="1" r:id="rId1"/></sheets></workbook>`;

    const contentTypes = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types"><Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/><Default Extension="xml" ContentType="application/xml"/><Override PartName="/xl/workbook.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml"/><Override PartName="/xl/worksheets/sheet1.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/><Override PartName="/xl/sharedStrings.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sharedStrings+xml"/></Types>`;

    const relsRoot = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="xl/workbook.xml"/></Relationships>`;

    const relsWorkbook = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet" Target="worksheets/sheet1.xml"/><Relationship Id="rId2" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/sharedStrings" Target="sharedStrings.xml"/></Relationships>`;

    // Build ZIP
    const filesInZip: { path: string; content: string }[] = [
      { path: '[Content_Types].xml', content: contentTypes },
      { path: '_rels/.rels', content: relsRoot },
      { path: 'xl/workbook.xml', content: workbookXML },
      { path: 'xl/_rels/workbook.xml.rels', content: relsWorkbook },
      { path: 'xl/worksheets/sheet1.xml', content: sheetXML },
      { path: 'xl/sharedStrings.xml', content: ssXML },
    ];

    return createZip(filesInZip);
  }

  function colToLetter(col: number): string {
    let s = '';
    col++;
    while (col > 0) {
      col--;
      s = String.fromCharCode(65 + (col % 26)) + s;
      col = Math.floor(col / 26);
    }
    return s;
  }

  function escapeXml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&apos;');
  }

  // Minimal ZIP file creator (no compression, store only)
  function createZip(files: { path: string; content: string }[]): Uint8Array {
    const encoder = new TextEncoder();
    const entries: { path: Uint8Array; data: Uint8Array; offset: number }[] = [];
    const parts: Uint8Array[] = [];
    let offset = 0;

    // Local file headers + data
    for (const file of files) {
      const pathBytes = encoder.encode(file.path);
      const dataBytes = encoder.encode(file.content);
      const header = new Uint8Array(30 + pathBytes.length);
      const view = new DataView(header.buffer);

      view.setUint32(0, 0x04034b50, true); // local file header signature
      view.setUint16(4, 20, true); // version needed
      view.setUint16(6, 0, true); // flags
      view.setUint16(8, 0, true); // compression (store)
      view.setUint16(10, 0, true); // mod time
      view.setUint16(12, 0, true); // mod date
      view.setUint32(14, crc32(dataBytes), true); // crc32
      view.setUint32(18, dataBytes.length, true); // compressed size
      view.setUint32(22, dataBytes.length, true); // uncompressed size
      view.setUint16(26, pathBytes.length, true); // filename length
      view.setUint16(28, 0, true); // extra field length
      header.set(pathBytes, 30);

      entries.push({ path: pathBytes, data: dataBytes, offset });
      parts.push(header, dataBytes);
      offset += header.length + dataBytes.length;
    }

    // Central directory
    const centralStart = offset;
    for (const entry of entries) {
      const cdHeader = new Uint8Array(46 + entry.path.length);
      const view = new DataView(cdHeader.buffer);

      view.setUint32(0, 0x02014b50, true); // central directory signature
      view.setUint16(4, 20, true); // version made by
      view.setUint16(6, 20, true); // version needed
      view.setUint16(8, 0, true); // flags
      view.setUint16(10, 0, true); // compression
      view.setUint16(12, 0, true); // mod time
      view.setUint16(14, 0, true); // mod date
      view.setUint32(16, crc32(entry.data), true); // crc32
      view.setUint32(20, entry.data.length, true); // compressed
      view.setUint32(24, entry.data.length, true); // uncompressed
      view.setUint16(28, entry.path.length, true); // filename length
      view.setUint16(30, 0, true); // extra length
      view.setUint16(32, 0, true); // comment length
      view.setUint16(34, 0, true); // disk start
      view.setUint16(36, 0, true); // internal attrs
      view.setUint32(38, 0, true); // external attrs
      view.setUint32(42, entry.offset, true); // local header offset
      cdHeader.set(entry.path, 46);

      parts.push(cdHeader);
      offset += cdHeader.length;
    }

    const centralSize = offset - centralStart;

    // End of central directory
    const eocd = new Uint8Array(22);
    const eocdView = new DataView(eocd.buffer);
    eocdView.setUint32(0, 0x06054b50, true);
    eocdView.setUint16(4, 0, true); // disk number
    eocdView.setUint16(6, 0, true); // disk with central dir
    eocdView.setUint16(8, entries.length, true); // entries on disk
    eocdView.setUint16(10, entries.length, true); // total entries
    eocdView.setUint32(12, centralSize, true); // central dir size
    eocdView.setUint32(16, centralStart, true); // central dir offset
    eocdView.setUint16(20, 0, true); // comment length
    parts.push(eocd);

    // Combine
    const totalLen = parts.reduce((sum, p) => sum + p.length, 0);
    const result = new Uint8Array(totalLen);
    let pos = 0;
    for (const part of parts) {
      result.set(part, pos);
      pos += part.length;
    }
    return result;
  }

  // CRC32
  function crc32(data: Uint8Array): number {
    let crc = 0xFFFFFFFF;
    for (let i = 0; i < data.length; i++) {
      crc ^= data[i];
      for (let j = 0; j < 8; j++) {
        crc = (crc >>> 1) ^ (crc & 1 ? 0xEDB88320 : 0);
      }
    }
    return (crc ^ 0xFFFFFFFF) >>> 0;
  }
</script>


