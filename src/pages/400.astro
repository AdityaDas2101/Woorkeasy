---
/**
 * 400 Bad Request
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Bad Request (400) | Woorkeasy"
  description="The request could not be processed due to invalid syntax. Return to Woorkeasy homepage."
  noIndex
>
  <section class="flex-1 flex items-center justify-center px-6 py-16 md:py-24">
    <div class="max-w-lg w-full">
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-level-4 dark:border dark:border-neutral-800 p-8 md:p-12 text-center">
        <p class="text-7xl md:text-8xl font-bold bg-gradient-to-br from-orange-400 via-amber-500 to-yellow-500 bg-clip-text text-transparent select-none">
          400
        </p>
        <div class="w-16 h-16 mx-auto mt-6 bg-amber-100 dark:bg-amber-900/30 rounded-full flex items-center justify-center">
          <svg class="w-8 h-8 text-amber-600 dark:text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <h1 class="display-md text-neutral-900 dark:text-neutral-100 mt-4">Bad Request</h1>
        <p class="body-md text-neutral-600 dark:text-neutral-400 mt-2">
          The request couldn't be processed due to invalid syntax or parameters.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
          <a href="/" class="btn-primary no-underline">Go Home</a>
          <a href="/contact/" class="btn-secondary no-underline">Report Issue</a>
        </div>
      </div>
      <div class="mt-6 p-4 bg-neutral-100 dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800">
        <p class="caption-mono text-neutral-500 text-center">Need help? Try our popular tools</p>
        <div class="flex flex-wrap justify-center gap-2 mt-3">
          <a href="/image/jpg-to-png" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">JPG to PNG</a>
          <a href="/image/compress" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Compress</a>
          <a href="/pdf/merge-pdf" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Merge PDF</a>
          <a href="/dev/base64" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Base64</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
