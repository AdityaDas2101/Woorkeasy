---
/**
 * Character Counter Tool
 * Live character, word, sentence, and paragraph count.
 * Includes reading time estimation and keyword density.
 */
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="Character Counter"
  metaTitle="Character Counter Online Free - Word Counter Tool | Woorkeasy"
  description="Count characters and words online free. Real-time character counter with word count, sentence count, and keyword density analysis. No upload."
  heading="Character Counter"
  category="Utility"
>
  <div id="counter-app">
    <!-- Text Input Area -->
    <div class="relative">
      <textarea
        id="text-input"
        class="w-full min-h-[300px] p-6 border border-neutral-200 rounded-lg body-md text-neutral-900 bg-white resize-y focus:outline-none focus:border-neutral-900 transition-colors"
        placeholder="Start typing or paste your text here..."
        autofocus
      ></textarea>
      <button
        id="clear-btn"
        class="absolute top-3 right-3 body-sm text-neutral-500 hover:text-neutral-900 transition-colors hidden"
      >
        Clear
      </button>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-4 mt-6">
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p id="char-count" class="display-md text-neutral-900">0</p>
        <p class="caption-mono text-neutral-500 mt-[var(--spacing-xxs)]">CHARACTERS</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p id="char-no-space" class="display-md text-neutral-900">0</p>
        <p class="caption-mono text-neutral-500 mt-[var(--spacing-xxs)]">NO SPACES</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p id="word-count" class="display-md text-neutral-900">0</p>
        <p class="caption-mono text-neutral-500 mt-[var(--spacing-xxs)]">WORDS</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p id="sentence-count" class="display-md text-neutral-900">0</p>
        <p class="caption-mono text-neutral-500 mt-[var(--spacing-xxs)]">SENTENCES</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p id="para-count" class="display-md text-neutral-900">0</p>
        <p class="caption-mono text-neutral-500 mt-[var(--spacing-xxs)]">PARAGRAPHS</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p id="read-time" class="display-md text-neutral-900">0s</p>
        <p class="caption-mono text-neutral-500 mt-[var(--spacing-xxs)]">READ TIME</p>
      </div>
    </div>

    <!-- Keyword Density -->
    <div id="keyword-section" class="hidden mt-8">
      <h2 class="display-sm text-neutral-900 mb-4">Top Keywords</h2>
      <div id="keyword-list" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2"></div>
    </div>
  </div>
</ToolLayout>

  <div slot="info">
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">How to Use Character Counter</h2>
      <ol class="list-decimal list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li>Type or paste your text into the large text area.</li>
        <li>Watch the live stats update in real time - characters, words, sentences, paragraphs, and reading time.</li>
        <li>Review keyword density analysis below the stats to understand your most frequent terms.</li>
      </ol>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Features</h2>
      <ul class="list-disc list-inside space-y-2 mt-4 body-md text-neutral-700 dark:text-neutral-300">
        <li><strong>Real-Time Counting</strong> - all metrics update instantly as you type or paste.</li>
        <li><strong>Comprehensive Stats</strong> - characters (with and without spaces), words, sentences, paragraphs, and reading time.</li>
        <li><strong>Keyword Density</strong> - identifies your most frequent words with usage count and density percentage.</li>
        <li><strong>Stop Word Filtering</strong> - common English stop words are excluded from keyword analysis for meaningful results.</li>
      </ul>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">Why Use Our Character Counter</h2>
      <p class="body-md text-neutral-700 dark:text-neutral-300 mt-4">Whether you're writing social media posts with character limits, SEO content with word count requirements, or academic papers with strict formatting rules, our character counter provides all the metrics you need at a glance. The real-time updates mean no button clicking - just type and watch your stats change instantly. The keyword density analysis helps optimize your content for search engines and readability by identifying overused or underused terms.</p>

      <h2 class="display-sm text-neutral-900 dark:text-neutral-100 mt-8">FAQs</h2>
      <div class="space-y-4 mt-4">
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">Does it count characters with or without spaces?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Both. The main count includes spaces, and a separate "No Spaces" counter shows characters excluding spaces. This is useful for platform-specific limits like Twitter or meta descriptions.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">How is reading time calculated?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">Reading time is based on an average reading speed of 200 words per minute. Results are shown in seconds for short texts and minutes for longer content, giving you a clear sense of your text's length.</p></div>
        <div><h3 class="body-md font-semibold text-neutral-900 dark:text-neutral-100">How does keyword density work?</h3><p class="body-md text-neutral-700 dark:text-neutral-300">The tool counts word frequency across your text, filters out common English stop words (the, and, is, etc.), and shows the top 12 keywords with their count and percentage of total words.</p></div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="bg-white dark:bg-neutral-900 rounded-xl p-6 md:p-8 shadow-level-3 dark:border dark:border-neutral-800 mt-6">
      <h2 class="display-sm text-neutral-900 dark:text-neutral-100">Related Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-4">
        <a href="/utility/web-to-image/" class="px-4 py-3 bg-neutral-100 dark:bg-neutral-800 rounded-lg body-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-center">Webpage to Image</a>
      </div>
    </section>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does it count characters with or without spaces?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Both. The main count includes spaces, and a separate 'No Spaces' counter shows characters excluding spaces."
        }
      },
      {
        "@type": "Question",
        "name": "How is reading time calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Reading time is based on an average reading speed of 200 words per minute. Results are shown in seconds for short texts and minutes for longer content."
        }
      },
      {
        "@type": "Question",
        "name": "How does keyword density work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tool counts word frequency, filters out common English stop words, and shows the top 12 keywords with their count and percentage of total words."
        }
      }
    ]
  }
  </script>

<script>
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const clearBtn = document.getElementById('clear-btn')!;
  const charCount = document.getElementById('char-count')!;
  const charNoSpace = document.getElementById('char-no-space')!;
  const wordCount = document.getElementById('word-count')!;
  const sentenceCount = document.getElementById('sentence-count')!;
  const paraCount = document.getElementById('para-count')!;
  const readTime = document.getElementById('read-time')!;
  const keywordSection = document.getElementById('keyword-section')!;
  const keywordList = document.getElementById('keyword-list')!;

  // Live counting on every input event
  textInput.addEventListener('input', updateCounts);

  clearBtn.addEventListener('click', () => {
    textInput.value = '';
    updateCounts();
  });

  function updateCounts() {
    const text = textInput.value;

    // Show/hide clear button
    clearBtn.classList.toggle('hidden', text.length === 0);

    // Characters
    charCount.textContent = text.length.toLocaleString();

    // Characters without spaces
    charNoSpace.textContent = text.replace(/\s/g, '').length.toLocaleString();

    // Words
    const words = text.trim() ? text.trim().split(/\s+/) : [];
    wordCount.textContent = words.length.toLocaleString();

    // Sentences (split on . ! ?)
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
    sentenceCount.textContent = sentences.length.toLocaleString();

    // Paragraphs
    const paragraphs = text.split(/\n\n+/).filter(p => p.trim().length > 0);
    paraCount.textContent = paragraphs.length.toLocaleString();

    // Reading time (average 200 words per minute)
    const minutes = words.length / 200;
    if (minutes < 1) {
      readTime.textContent = `${Math.ceil(minutes * 60)}s`;
    } else {
      readTime.textContent = `${Math.ceil(minutes)}m`;
    }

    // Keyword density
    updateKeywords(words);
  }

  function updateKeywords(words: string[]) {
    if (words.length < 5) {
      keywordSection.classList.add('hidden');
      return;
    }

    // Count word frequency (exclude common stop words)
    const stopWords = new Set(['the', 'a', 'an', 'and', 'or', 'but', 'in', 'on', 'at', 'to', 'for', 'of', 'with', 'by', 'is', 'it', 'this', 'that', 'are', 'was', 'be', 'have', 'has', 'had', 'not', 'from', 'as', 'i', 'we', 'you', 'they', 'he', 'she', 'do', 'does', 'did', 'will', 'would', 'could', 'should', 'can', 'may', 'if', 'so', 'no', 'my', 'your', 'our', 'their', 'its', 'his', 'her']);

    const freq: Record<string, number> = {};
    for (const word of words) {
      const lower = word.toLowerCase().replace(/[^a-z0-9]/g, '');
      if (lower.length > 2 && !stopWords.has(lower)) {
        freq[lower] = (freq[lower] || 0) + 1;
      }
    }

    const sorted = Object.entries(freq)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 12);

    if (sorted.length === 0) {
      keywordSection.classList.add('hidden');
      return;
    }

    keywordSection.classList.remove('hidden');
    keywordList.innerHTML = sorted.map(([word, count]) => {
      const density = ((count / words.length) * 100).toFixed(1);
      return `
        <div class="flex items-center justify-between p-[var(--spacing-xs)] bg-neutral-50 rounded-md">
          <span class="body-sm text-neutral-900">${word}</span>
          <span class="caption-mono text-neutral-500">${count}- (${density}%)</span>
        </div>
      `;
    }).join('');
  }

  // Initialize with empty state
  updateCounts();
</script>



