---
/**
 * 403 Forbidden
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Forbidden (403) | Woorkeasy"
  description="You do not have permission to access this resource. Return to Woorkeasy homepage."
  noIndex
>
  <section class="flex-1 flex items-center justify-center px-6 py-16 md:py-24">
    <div class="max-w-lg w-full">
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-level-4 dark:border dark:border-neutral-800 p-8 md:p-12 text-center">
        <p class="text-7xl md:text-8xl font-bold bg-gradient-to-br from-red-500 via-rose-500 to-pink-500 bg-clip-text text-transparent select-none">
          403
        </p>
        <div class="w-16 h-16 mx-auto mt-6 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center">
          <svg class="w-8 h-8 text-red-600 dark:text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            <circle cx="12" cy="16" r="0.5" fill="currentColor"/>
            <line x1="12" y1="16" x2="12" y2="14"/>
          </svg>
        </div>
        <h1 class="display-md text-neutral-900 dark:text-neutral-100 mt-4">Access Denied</h1>
        <p class="body-md text-neutral-600 dark:text-neutral-400 mt-2">
          You don't have permission to access this resource.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
          <a href="/" class="btn-primary no-underline">Go Home</a>
          <a href="/contact/" class="btn-secondary no-underline">Contact Us</a>
        </div>
      </div>
      <div class="mt-6 p-4 bg-neutral-100 dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800">
        <p class="caption-mono text-neutral-500 text-center">Explore available tools</p>
        <div class="flex flex-wrap justify-center gap-2 mt-3">
          <a href="/image/background-remover" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Bg Remover</a>
          <a href="/image/crop" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Crop</a>
          <a href="/pdf/split-pdf" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Split PDF</a>
          <a href="/utility/character-counter" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Char Counter</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
