---
/**
 * 503 Service Unavailable
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Service Unavailable (503) | Woorkeasy"
  description="Woorkeasy is temporarily unavailable due to maintenance or high traffic. Please try again shortly."
  noIndex
>
  <section class="flex-1 flex items-center justify-center px-6 py-16 md:py-24">
    <div class="max-w-lg w-full">
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-level-4 dark:border dark:border-neutral-800 p-8 md:p-12 text-center">
        <p class="text-7xl md:text-8xl font-bold bg-gradient-to-br from-cyan-500 via-blue-500 to-indigo-500 bg-clip-text text-transparent select-none">
          503
        </p>
        <div class="w-16 h-16 mx-auto mt-6 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center">
          <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/>
            <rect x="2" y="14" width="20" height="8" rx="2" ry="2"/>
            <line x1="6" y1="6" x2="6.01" y2="6"/>
            <line x1="6" y1="18" x2="6.01" y2="18"/>
          </svg>
        </div>
        <h1 class="display-md text-neutral-900 dark:text-neutral-100 mt-4">Service Unavailable</h1>
        <p class="body-md text-neutral-600 dark:text-neutral-400 mt-2">
          We're temporarily offline for maintenance or experiencing high traffic. Please check back shortly.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
          <a href="/" class="btn-primary no-underline">Try Again</a>
          <a href="/contact/" class="btn-secondary no-underline">Contact Us</a>
        </div>
        <p class="body-sm text-neutral-500 dark:text-neutral-500 mt-5">
          Need urgent help? Email <a href="mailto:woorkeasy@gmail.com" class="text-blue-600 dark:text-blue-400 hover:underline">woorkeasy@gmail.com</a>
        </p>
      </div>
      <div class="mt-6 p-4 bg-neutral-100 dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800">
        <p class="caption-mono text-neutral-500 text-center">While you wait, here are some popular tools</p>
        <div class="flex flex-wrap justify-center gap-2 mt-3">
          <a href="/image/jpg-to-png" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">JPG to PNG</a>
          <a href="/image/compress" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Compress</a>
          <a href="/pdf/merge-pdf" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">Merge PDF</a>
          <a href="/finance/ofx-to-excel" class="px-3 py-1.5 bg-white dark:bg-neutral-800 rounded-lg body-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors shadow-level-1">OFX to Excel</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
