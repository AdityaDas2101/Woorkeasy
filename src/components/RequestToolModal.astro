---
/**
 * RequestToolModal Component
 * Dual-purpose modal for tool requests and website feedback.
 * On submit, opens mailto with structured body.
 * Trigger via `data-request-tool` (tool request mode) or `data-feedback` (feedback mode).
 */
---

<dialog
  id="request-tool-modal"
  class="fixed inset-0 z-50 m-auto w-full max-w-lg max-h-[90vh] bg-white dark:bg-neutral-900 rounded-2xl shadow-2xl border border-neutral-200 dark:border-neutral-700 backdrop:bg-black/50 backdrop:backdrop-blur-sm open:flex open:flex-col p-0"
>
  <form id="rt-form" method="dialog" class="flex flex-col max-h-[90vh]">
    <!-- Header -->
    <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b border-neutral-200 dark:border-neutral-700">
      <div class="flex items-center gap-2 bg-neutral-100 dark:bg-neutral-800 rounded-lg p-0.5">
        <button type="button" id="rt-mode-request" class="mode-pill px-3 py-1.5 text-sm font-medium rounded-md transition-colors bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 shadow-sm">Request a Tool</button>
        <button type="button" id="rt-mode-feedback" class="mode-pill px-3 py-1.5 text-sm font-medium rounded-md transition-colors text-neutral-500 dark:text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-300">Give Feedback</button>
      </div>
      <button
        type="button"
        id="rt-close"
        class="flex items-center justify-center w-8 h-8 rounded-lg text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
        aria-label="Close"
      >
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none">
          <path d="M4 4l8 8m0-8l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="flex-1 overflow-y-auto px-6 py-5">
      <!-- Tool Request fields -->
      <div id="rt-fields-request">
        <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-4">
          Tell us what tool you need. We'll build it and let you know.
        </p>

        <div class="space-y-4">
          <div>
            <label for="rt-name" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Your Name</label>
            <input
              id="rt-name" type="text" required
              class="w-full px-3 py-2.5 text-sm bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-900/20 dark:focus:ring-neutral-100/20"
              placeholder="e.g. John Doe"
            />
          </div>

          <div>
            <label for="rt-email" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Your Email <span class="text-neutral-400 font-normal">(optional)</span></label>
            <input
              id="rt-email" type="email"
              class="w-full px-3 py-2.5 text-sm bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-900/20 dark:focus:ring-neutral-100/20"
              placeholder="john@example.com"
            />
          </div>

          <div>
            <label for="rt-category" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Category</label>
            <select
              id="rt-category"
              class="w-full px-3 py-2.5 text-sm bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-neutral-900/20 dark:focus:ring-neutral-100/20"
            >
              <option value="Image">Image</option>
              <option value="PDF">PDF</option>
              <option value="Finance">Finance</option>
              <option value="Dev">Dev</option>
              <option value="Utility">Utility</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label for="rt-description" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Tool Description</label>
            <textarea
              id="rt-description" required rows="5"
              class="w-full px-3 py-2.5 text-sm bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-900/20 dark:focus:ring-neutral-100/20 resize-none"
              placeholder="Describe the tool you need — what should it do?"
            ></textarea>
          </div>
        </div>
      </div>

      <!-- Feedback fields -->
      <div id="rt-fields-feedback" class="hidden">
        <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-4">
          Help us improve Woorkeasy. Share feedback or report issues.
        </p>

        <div class="space-y-4">
          <div>
            <label for="fd-name" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Your Name <span class="text-neutral-400 font-normal">(optional)</span></label>
            <input
              id="fd-name" type="text"
              class="w-full px-3 py-2.5 text-sm bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-900/20 dark:focus:ring-neutral-100/20"
              placeholder="e.g. John Doe"
            />
          </div>

          <div>
            <label for="fd-email" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Your Email <span class="text-neutral-400 font-normal">(optional)</span></label>
            <input
              id="fd-email" type="email"
              class="w-full px-3 py-2.5 text-sm bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-900/20 dark:focus:ring-neutral-100/20"
              placeholder="john@example.com"
            />
          </div>

          <div>
            <label for="fd-type" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Feedback Type</label>
            <select
              id="fd-type"
              class="w-full px-3 py-2.5 text-sm bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-neutral-900/20 dark:focus:ring-neutral-100/20"
            >
              <option value="General Improvement">General Improvement</option>
              <option value="Bug Report">Bug Report</option>
              <option value="Feature Suggestion">Feature Suggestion</option>
              <option value="UI/UX Feedback">UI/UX Feedback</option>
              <option value="Performance Issue">Performance Issue</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label for="fd-message" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Your Feedback</label>
            <textarea
              id="fd-message" required rows="5"
              class="w-full px-3 py-2.5 text-sm bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-900/20 dark:focus:ring-neutral-100/20 resize-none"
              placeholder="What can we improve? Any issues or suggestions?"
            ></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-neutral-200 dark:border-neutral-700">
      <button type="button" id="rt-cancel" class="px-4 py-2 text-sm font-medium text-neutral-600 dark:text-neutral-400 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors">Cancel</button>
      <button type="submit" id="rt-submit" class="px-5 py-2 text-sm font-medium text-white bg-neutral-900 dark:bg-white dark:text-neutral-900 rounded-lg hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-colors">Send</button>
    </div>
  </form>
</dialog>

<script>
  const modal = document.getElementById('request-tool-modal') as HTMLDialogElement;
  const form = document.getElementById('rt-form') as HTMLFormElement;

  // Mode toggle
  const modeRequest = document.getElementById('rt-mode-request') as HTMLButtonElement;
  const modeFeedback = document.getElementById('rt-mode-feedback') as HTMLButtonElement;
  const fieldsRequest = document.getElementById('rt-fields-request')!;
  const fieldsFeedback = document.getElementById('rt-fields-feedback')!;

  // Request fields
  const rtName = document.getElementById('rt-name') as HTMLInputElement;
  const rtEmail = document.getElementById('rt-email') as HTMLInputElement;
  const rtCategory = document.getElementById('rt-category') as HTMLSelectElement;
  const rtDesc = document.getElementById('rt-description') as HTMLTextAreaElement;

  // Feedback fields
  const fdName = document.getElementById('fd-name') as HTMLInputElement;
  const fdEmail = document.getElementById('fd-email') as HTMLInputElement;
  const fdType = document.getElementById('fd-type') as HTMLSelectElement;
  const fdMessage = document.getElementById('fd-message') as HTMLTextAreaElement;

  const closeBtn = document.getElementById('rt-close') as HTMLButtonElement;
  const cancelBtn = document.getElementById('rt-cancel') as HTMLButtonElement;
  const submitBtn = document.getElementById('rt-submit') as HTMLButtonElement;

  let currentMode: 'request' | 'feedback' = 'request';

  function setMode(mode: 'request' | 'feedback') {
    currentMode = mode;
    const isRequest = mode === 'request';

    modeRequest.className = `mode-pill px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${isRequest ? 'bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 shadow-sm' : 'text-neutral-500 dark:text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-300'}`;
    modeFeedback.className = `mode-pill px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${!isRequest ? 'bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 shadow-sm' : 'text-neutral-500 dark:text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-300'}`;

    fieldsRequest.classList.toggle('hidden', !isRequest);
    fieldsFeedback.classList.toggle('hidden', isRequest);

    rtName.required = isRequest;
    rtDesc.required = isRequest;
    fdMessage.required = !isRequest;

    submitBtn.textContent = isRequest ? 'Send Request' : 'Send Feedback';
  }

  modeRequest.addEventListener('click', () => setMode('request'));
  modeFeedback.addEventListener('click', () => setMode('feedback'));

  function openModal(mode: 'request' | 'feedback' = 'request') {
    form.reset();
    setMode(mode);
    modal.showModal();
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.close();
    document.body.style.overflow = '';
  }

  (window as any).openRequestToolModal = () => openModal('request');
  (window as any).openFeedbackModal = () => openModal('feedback');

  // Trigger via data attributes
  document.addEventListener('click', (e) => {
    const reqTrigger = (e.target as HTMLElement).closest('[data-request-tool]');
    if (reqTrigger) { e.preventDefault(); openModal('request'); return; }
    const fdTrigger = (e.target as HTMLElement).closest('[data-feedback]');
    if (fdTrigger) { e.preventDefault(); openModal('feedback'); }
  });

  closeBtn.addEventListener('click', closeModal);
  cancelBtn.addEventListener('click', closeModal);

  modal.addEventListener('close', () => { document.body.style.overflow = ''; });
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  // Submit
  form.addEventListener('submit', (e) => {
    e.preventDefault();

    if (currentMode === 'request') {
      const name = rtName.value.trim();
      const email = rtEmail.value.trim();
      const category = rtCategory.value;
      const description = rtDesc.value.trim();
      if (!name || !description) return;

      const subject = encodeURIComponent(`Tool Request: ${category} — ${name}`);
      const body = encodeURIComponent(
        `Tool Request\n${'='.repeat(40)}\n\n` +
        `Name: ${name}\n` +
        `Email: ${email || '(not provided)'}\n` +
        `Category: ${category}\n` +
        `Page: ${window.location.href}\n\n` +
        `Description:\n${description}\n`
      );

      closeModal();
      window.location.href = `mailto:woorkeasy@gmail.com?subject=${subject}&body=${body}`;

    } else {
      const name = fdName.value.trim();
      const email = fdEmail.value.trim();
      const type = fdType.value;
      const message = fdMessage.value.trim();
      if (!message) return;

      const subject = encodeURIComponent(`Feedback: ${type}`);
      const body = encodeURIComponent(
        `Website Feedback\n${'='.repeat(40)}\n\n` +
        `Name: ${name || '(not provided)'}\n` +
        `Email: ${email || '(not provided)'}\n` +
        `Type: ${type}\n` +
        `Page: ${window.location.href}\n\n` +
        `Message:\n${message}\n`
      );

      closeModal();
      window.location.href = `mailto:woorkeasy@gmail.com?subject=${subject}&body=${body}`;
    }
  });
</script>
