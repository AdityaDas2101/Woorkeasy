---
/**
 * Header Component
 * Sticky nav bar with logo, dropdown navigation, and CTA.
 * Follows Vercel-style design: 64px height, clean links, black CTA.
 */
import LanguageSwitcher from './LanguageSwitcher.astro';

const navDropdowns = [
  {
    label: 'Image Tools',
    i18nKey: 'nav.imageTools',
    description: 'Convert, edit, and optimize your images with ease.',
    items: [
      { name: 'JPG to PNG', href: '/image/jpg-to-png' },
      { name: 'PNG to JPG', href: '/image/png-to-jpg' },
      { name: 'JPG/PNG to WebP', href: '/image/to-webp' },
      { name: 'WebP to JPG/PNG', href: '/image/webp-converter' },
      { name: 'HEIC to JPG', href: '/image/heic-to-jpg' },
      { name: 'Compress Image', href: '/image/compress' },
      { name: 'Crop Image', href: '/image/crop' },
      { name: 'Rotate & Flip', href: '/image/rotate' },
      { name: 'Add Watermark', href: '/image/watermark' },
      { name: 'Remove Background', href: '/image/background-remover' },
    ],
  },
  {
    label: 'PDF Tools',
    i18nKey: 'nav.pdfTools',
    description: 'Convert, merge, split, and manage PDF documents.',
    items: [
      { name: 'JPG to PDF', href: '/pdf/jpg-to-pdf' },
      { name: 'PDF to Image', href: '/pdf/pdf-to-image' },
      { name: 'Merge PDF', href: '/pdf/merge-pdf' },
      { name: 'Split PDF', href: '/pdf/split-pdf' },
      { name: 'Rotate PDF', href: '/pdf/rotate-pdf' },
    ],
  },
  {
    label: 'Finance',
    i18nKey: 'nav.finance',
    description: 'Process financial statements and convert formats.',
    items: [
      { name: 'OFX to Excel', href: '/finance/ofx-to-excel' },
      { name: 'QFX to Excel', href: '/finance/qfx-to-excel' },
      { name: 'Excel to CSV', href: '/finance/excel-to-csv' },
      { name: 'CSV to Excel', href: '/finance/csv-to-excel' },
    ],
  },
  {
    label: 'Dev Tools',
    i18nKey: 'nav.devTools',
    description: 'Developer utilities for everyday coding tasks.',
    items: [
      { name: 'Base64 Encode/Decode', href: '/dev/base64' },
      { name: 'URL Encode/Decode', href: '/dev/url-encode' },
      { name: 'JSON Formatter', href: '/dev/json-formatter' },
    ],
  },
  {
    label: 'Utility',
    i18nKey: 'nav.utility',
    description: 'Handy tools for quick everyday tasks.',
    items: [
      { name: 'Character Counter', href: '/utility/character-counter' },
      { name: 'Web to Image / PDF', href: '/utility/web-to-image' },
    ],
  },
];
---

<header class="sticky top-0 z-50 bg-white/80 dark:bg-neutral-950/80 backdrop-blur-md border-b border-neutral-200 dark:border-neutral-800 h-16">
  <nav class="max-w-5xl mx-auto h-full flex items-center justify-between px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-xl font-semibold text-neutral-900 dark:text-neutral-100 tracking-tight">Woorkeasy</span>
    </a>

    <!-- Desktop Nav with Mega Dropdowns -->
    <div class="hidden md:flex items-center gap-1">
      {navDropdowns.map((dropdown) => (
        <div class="relative group">
          <button
            class="nav-trigger text-sm text-neutral-600 dark:text-neutral-400 px-3 py-2 rounded-full no-underline hover:text-neutral-900 dark:hover:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors inline-flex items-center gap-1 cursor-pointer"
            data-i18n={dropdown.i18nKey}
          >
            {dropdown.label}
            <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" viewBox="0 0 12 12" fill="none">
              <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <!-- Mega Dropdown: left = description, right = links -->
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-[opacity,visibility] duration-300 ease-out">
            <div class="group-hover:translate-y-0 translate-y-3 transition-transform duration-300 ease-out">
              <div class="flex bg-white dark:bg-neutral-900 rounded-2xl border border-neutral-200/70 dark:border-neutral-700/70 shadow-[0_4px_24px_-4px_rgba(0,0,0,0.12),0_0_0_1px_rgba(0,0,0,0.05)] dark:shadow-[0_4px_24px_-4px_rgba(0,0,0,0.4),0_0_0_1px_rgba(255,255,255,0.06)] overflow-hidden backdrop-blur-sm w-max max-w-[90vw]">
                <!-- Left: Description panel -->
                <div class="w-[180px] shrink-0 p-5 flex flex-col justify-center bg-neutral-50/50 dark:bg-neutral-800/30 border-r border-neutral-100 dark:border-neutral-800">
                  <div class="text-[11px] font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-widest mb-2">{dropdown.label}</div>
                  <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">{dropdown.description}</p>
                </div>
                <!-- Right: Links grid -->
                <div class="flex-1 p-3">
                  <div class="grid grid-cols-2 gap-x-4 gap-y-0">
                    {dropdown.items.map((item) => (
                      <a
                        href={item.href}
                        class="flex items-center gap-2.5 px-3 py-2.5 text-sm text-neutral-600 dark:text-neutral-400 no-underline rounded-xl hover:text-neutral-900 dark:hover:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
                      >
                        <span class="w-1.5 h-1.5 rounded-full bg-neutral-300 dark:bg-neutral-600 shrink-0" />
                        <span class="whitespace-nowrap">{item.name}</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Right side: Language + Dark Mode Toggle + CTA + Mobile Menu -->
    <div class="flex items-center gap-2">
      <!-- Language Switcher -->
      <LanguageSwitcher />

      <!-- Dark Mode Toggle -->
      <button
        id="theme-toggle"
        class="flex items-center justify-center w-8 h-8 rounded-md hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
        aria-label="Toggle dark mode"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="sun-icon" class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="moon-icon" class="w-4 h-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <button
        data-request-tool
        class="hidden sm:inline-flex items-center text-sm text-neutral-600 dark:text-neutral-400 px-3 py-1.5 rounded-md border border-neutral-200 dark:border-neutral-700 no-underline hover:border-neutral-900 dark:hover:border-neutral-300 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors cursor-pointer"
        data-i18n="nav.requestTool"
      >
        Request a Tool
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="mobile-menu-btn md:hidden flex flex-col items-center justify-center w-9 h-9 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors gap-[3px]"
        aria-label="Open menu"
      >
        <span class="hamburger-line hamburger-line-top block w-4 h-px bg-current rounded-full" />
        <span class="hamburger-line hamburger-line-middle block w-4 h-px bg-current rounded-full" />
        <span class="hamburger-line hamburger-line-bottom block w-4 h-px bg-current rounded-full" />
      </button>
    </div>
  </nav>

</header>

<!-- Backdrop overlay -->
<div id="mobile-backdrop" class="fixed inset-0 top-16 bg-black/20 dark:bg-black/40 z-30 md:hidden" />

<!-- Mobile Menu Overlay (outside header to avoid backdrop-filter containing block) -->
<div id="mobile-menu" class="fixed top-16 right-0 bottom-0 w-72 max-w-[85vw] bg-white dark:bg-neutral-950 z-40 overflow-y-auto md:hidden border-l border-neutral-200 dark:border-neutral-800">
  <div class="flex flex-col py-3">
    {navDropdowns.map((dropdown) => (
      <div class="mobile-dropdown border-b border-neutral-100 dark:border-neutral-800 last:border-b-0">
        <button class="mobile-dropdown-btn w-full flex items-center justify-between text-sm font-medium text-neutral-900 dark:text-neutral-100 px-5 py-3.5 cursor-pointer hover:bg-neutral-50 dark:hover:bg-neutral-900 transition-colors" data-i18n={dropdown.i18nKey}>
          <span>{dropdown.label}</span>
          <svg class="w-3.5 h-3.5 text-neutral-400 transition-transform duration-300" viewBox="0 0 16 16" fill="none">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="mobile-dropdown-content">
          <div class="px-5 pb-4 pt-1">
            <div class="flex flex-col gap-0.5">
              {dropdown.items.map((item) => (
                <a
                  href={item.href}
                  class="flex items-center gap-2.5 text-sm text-neutral-600 dark:text-neutral-400 py-2 px-2.5 no-underline rounded-lg hover:text-neutral-900 dark:hover:text-neutral-100 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-neutral-300 dark:bg-neutral-600 shrink-0" />
                  <span>{item.name}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}
    <div class="px-5 pt-3">
      <button
        data-request-tool
        class="block w-full text-center text-sm font-medium text-neutral-600 dark:text-neutral-400 px-4 py-2.5 rounded-lg border border-neutral-200 dark:border-neutral-700 no-underline hover:border-neutral-900 dark:hover:border-neutral-300 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors cursor-pointer"
        data-i18n="nav.requestTool"
      >
        Request a Tool
      </button>
    </div>
  </div>
</div>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-backdrop');

  function openMenu() {
    menu?.classList.add('open');
    backdrop?.classList.add('open');
    btn?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('open');
    backdrop?.classList.remove('open');
    btn?.classList.remove('open');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => {
    if (menu?.classList.contains('open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  backdrop?.addEventListener('click', closeMenu);

  // Mobile accordion dropdowns with smooth max-height animation
  document.querySelectorAll('.mobile-dropdown-btn').forEach((button) => {
    button.addEventListener('click', () => {
      const content = button.nextElementSibling as HTMLElement;
      const arrow = button.querySelector('svg');

      if (content.style.maxHeight && content.style.maxHeight !== '0px') {
        content.style.maxHeight = '0px';
        arrow?.classList.remove('rotate-180');
      } else {
        content.style.maxHeight = content.scrollHeight + 'px';
        arrow?.classList.add('rotate-180');
      }
    });
  });

  // Close menu on nav link click
  document.querySelectorAll('#mobile-menu a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Dark mode toggle
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
